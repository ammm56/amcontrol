<!-- AMControlWPF\Views\Config\ActuatorManagementView.xaml -->
<UserControl x:Class="AMControlWPF.Views.Config.ActuatorManagementView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent"
             Loaded="UserControl_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- ════ 顶部工具栏 ════ -->
        <Border Grid.Row="0"
                Padding="12,10"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="执行器配置" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="ButtonRefresh"
                            MinWidth="72"
                            Margin="0,0,8,0"
                            Click="ButtonRefresh_OnClick"
                            Content="刷新" />
                    <Button x:Name="ButtonAdd"
                            MinWidth="88"
                            Click="ButtonAdd_OnClick"
                            Content="+ 新增" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════ 主体三列布局 ════ -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>

            <!-- ══════════ 左列：执行器列表 ══════════ -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <TextBlock Grid.Row="0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="执行器列表" />

                    <!-- 类型筛选按钮（标题行） -->
                    <WrapPanel Grid.Row="2" Orientation="Horizontal">
                        <Button x:Name="ButtonFilterAll"
                                Height="26" MinWidth="42"
                                Margin="0,0,4,4" Padding="8,0"
                                FontSize="12" Tag="All"
                                Click="ButtonFilter_OnClick"
                                Content="全部" />
                        <Button x:Name="ButtonFilterCylinder"
                                Height="26" MinWidth="42"
                                Margin="0,0,4,4" Padding="8,0"
                                FontSize="12" Tag="Cylinder"
                                Click="ButtonFilter_OnClick"
                                Content="气缸" />
                        <Button x:Name="ButtonFilterVacuum"
                                Height="26" MinWidth="42"
                                Margin="0,0,4,4" Padding="8,0"
                                FontSize="12" Tag="Vacuum"
                                Click="ButtonFilter_OnClick"
                                Content="真空" />
                        <Button x:Name="ButtonFilterStackLight"
                                Height="26" MinWidth="42"
                                Margin="0,0,4,4" Padding="8,0"
                                FontSize="12" Tag="StackLight"
                                Click="ButtonFilter_OnClick"
                                Content="灯塔" />
                        <Button x:Name="ButtonFilterGripper"
                                Height="26" MinWidth="42"
                                Margin="0,0,4,4" Padding="8,0"
                                FontSize="12" Tag="Gripper"
                                Click="ButtonFilter_OnClick"
                                Content="夹爪" />
                    </WrapPanel>

                    <!-- 执行器列表 -->
                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ListBox x:Name="ListBoxActuators"
                                 ItemsSource="{Binding AllActuatorItems}"
                                 SelectedItem="{Binding SelectedActuatorItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 SelectionChanged="ListBoxActuators_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Effect="{StaticResource EffectShadow2}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Margin="10,8,10,8">
                                            <!-- 类型徽章 -->
                                            <Border Padding="5,2"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,6">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#607D8B" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ActuatorType}" Value="Cylinder">
                                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActuatorType}" Value="Vacuum">
                                                                <Setter Property="Background" Value="#03A9F4" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActuatorType}" Value="StackLight">
                                                                <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActuatorType}" Value="Gripper">
                                                                <Setter Property="Background" Value="#9C27B0" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           Text="{Binding TypeDisplay}" />
                                            </Border>
                                            <!-- 显示名称 -->
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding DisplayName}" />
                                            <!-- 名称标识 -->
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="11"
                                                       Opacity="0.6"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding Name}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ══════════ 中列：磁贴卡片 ══════════ -->
            <Border Grid.Column="2"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <!-- 无数据占位 -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasActuatorItems, Converter={StaticResource Boolean2VisibilityReConverter}}">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="42"
                                   Opacity="0.10"
                                   Text="◉" />
                        <TextBlock Margin="0,12,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Opacity="0.35"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="暂无执行器数据" />
                    </StackPanel>

                    <!-- 磁贴卡片列表 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding HasActuatorItems, Converter={StaticResource Boolean2VisibilityConverter}}">
                        <ListBox x:Name="ListBoxActuatorCards"
                                 ItemsSource="{Binding AllActuatorItems}"
                                 SelectedItem="{Binding SelectedActuatorItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="4">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="6" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="150"
                                            Padding="10,9"
                                            CornerRadius="6"
                                            Cursor="Hand"
                                            BorderThickness="2"
                                            Effect="{StaticResource EffectShadow2}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                        <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <!-- 类型徽章 -->
                                            <Border Padding="6,2"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#607D8B" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ActuatorType}" Value="Cylinder">
                                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActuatorType}" Value="Vacuum">
                                                                <Setter Property="Background" Value="#03A9F4" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActuatorType}" Value="StackLight">
                                                                <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActuatorType}" Value="Gripper">
                                                                <Setter Property="Background" Value="#9C27B0" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           Text="{Binding TypeDisplay}" />
                                            </Border>

                                            <!-- 显示名称 -->
                                            <TextBlock FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="38"
                                                       Margin="0,0,0,4"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding DisplayName}" />

                                            <!-- 名称标识 -->
                                            <TextBlock FontSize="11"
                                                       Opacity="0.55"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,6"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding Name}" />

                                            <!-- 启用状态角标 -->
                                            <Border Padding="5,2"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E0E0E0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Background" Value="#C8E6C9" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="10">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#757575" />
                                                            <Setter Property="Text" Value="● 已禁用" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                    <Setter Property="Foreground" Value="#2E7D32" />
                                                                    <Setter Property="Text" Value="● 已启用" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ══════════ 右列：详情面板 ══════════ -->
            <Border Grid.Column="4"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <!-- 未选中占位 -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsActuatorSelected, Converter={StaticResource Boolean2VisibilityReConverter}}">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="28"
                                   Opacity="0.15"
                                   Text="☰" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Opacity="0.4"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="请点击执行器查看详情" />
                    </StackPanel>

                    <!-- 详情内容 -->
                    <DockPanel x:Name="DetailPanel"
                               Visibility="{Binding IsActuatorSelected, Converter={StaticResource Boolean2VisibilityConverter}}">

                        <!-- 底部操作按钮 -->
                        <Border DockPanel.Dock="Bottom"
                                Padding="14,10"
                                CornerRadius="0,0,8,8"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Click="ButtonEdit_OnClick"
                                        Content="编辑" />
                                <Button Grid.Column="2"
                                        Foreground="{DynamicResource DangerBrush}"
                                        Click="ButtonDelete_OnClick"
                                        Content="删除" />
                            </Grid>
                        </Border>

                        <!-- 详情滚动区 -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="DetailContent"
                                        Margin="16,14,16,10" />
                        </ScrollViewer>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ════ 底部状态栏 ════ -->
        <TextBlock x:Name="TextBlockStatus"
                   Grid.Row="2"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Opacity="0.55"
                   Text="加载中..." />
    </Grid>
</UserControl>