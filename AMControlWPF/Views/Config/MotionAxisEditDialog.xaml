<hc:GlowWindow x:Class="AMControlWPF.Views.Config.MotionAxisEditDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               Title="轴拓扑配置"
               Width="520"
               Height="640"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               Background="{DynamicResource RegionBrush}">

    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="16">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0"
                            Padding="20,16"
                            CornerRadius="14,14,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock x:Name="TextBlockTitle"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="新增轴拓扑" />
                    </Border>

                    <!-- 表单区 -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="20,12,20,8"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- ── 基础标识 ── -->
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="基础标识" />

                            <TextBlock Margin="0,0,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="逻辑轴号 (LogicalAxis)" />
                            <TextBox x:Name="TextBoxLogicalAxis"
                                     Height="36"
                                     VerticalContentAlignment="Center"
                                     MaxLength="5" />

                            <TextBlock Margin="0,10,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="内部名称 *" />
                            <TextBox x:Name="TextBoxName"
                                     Height="36"
                                     VerticalContentAlignment="Center"
                                     MaxLength="64" />

                            <TextBlock Margin="0,10,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="显示名称（界面展示用）" />
                            <TextBox x:Name="TextBoxDisplayName"
                                     Height="36"
                                     VerticalContentAlignment="Center"
                                     MaxLength="64" />

                            <TextBlock Margin="0,10,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="轴分类" />
                            <ComboBox x:Name="ComboBoxAxisCategory" Height="36">
                                <ComboBoxItem Content="Linear（直线轴）"         Tag="Linear" />
                                <ComboBoxItem Content="Rotary（旋转轴）"         Tag="Rotary" />
                                <ComboBoxItem Content="GantryMaster（龙门主轴）" Tag="GantryMaster" />
                                <ComboBoxItem Content="GantrySlave（龙门从轴）"  Tag="GantrySlave" />
                                <ComboBoxItem Content="Virtual（虚拟轴）"        Tag="Virtual" />
                                <ComboBoxItem Content="Other（其他）"            Tag="Other" />
                            </ComboBox>

                            <!-- ── 物理映射 ── -->
                            <Rectangle Height="1"
                                       Margin="0,14,0,10"
                                       Fill="{DynamicResource BorderBrush}"
                                       Opacity="0.5" />
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="物理映射" />

                            <!-- 行 1：所属控制卡 + 卡内轴编号 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="所属控制卡 *" />
                                    <ComboBox x:Name="ComboBoxCardId"
                                              Height="36"
                                              SelectionChanged="ComboBoxCardId_OnSelectionChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,2"
                                                            VerticalAlignment="Center">
                                                    <Border Padding="6,2"
                                                            CornerRadius="3"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Background="{DynamicResource PrimaryBrush}">
                                                        <TextBlock Text="{Binding CardId, StringFormat='#{0}'}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White" />
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="10"
                                                                   Opacity="0.6"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="Text" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="卡内轴编号 (AxisId) *" />
                                    <ComboBox x:Name="ComboBoxAxisId" Height="36" />
                                </StackPanel>
                            </Grid>

                            <!-- 行 2：物理内核号 + 物理轴号（均依赖所选控制卡动态生成） -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="物理内核号 (PhysicalCore)" />
                                    <ComboBox x:Name="ComboBoxPhysicalCore" Height="36" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="物理轴号 (PhysicalAxis)" />
                                    <ComboBox x:Name="ComboBoxPhysicalAxis" Height="36" />
                                </StackPanel>
                            </Grid>

                            <!-- ── 状态与排序 ── -->
                            <Rectangle Height="1"
                                       Margin="0,14,0,10"
                                       Fill="{DynamicResource BorderBrush}"
                                       Opacity="0.5" />
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="状态与排序" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="CheckBoxIsEnabled"
                                          Grid.Column="0"
                                          VerticalAlignment="Center"
                                          Content="启用此轴"
                                          Foreground="{DynamicResource PrimaryTextBrush}" />
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="排序号" />
                                    <TextBox x:Name="TextBoxSortOrder"
                                             Height="36"
                                             VerticalContentAlignment="Center"
                                             MaxLength="4" />
                                </StackPanel>
                            </Grid>

                            <!-- ── 说明与备注 ── -->
                            <Rectangle Height="1"
                                       Margin="0,14,0,10"
                                       Fill="{DynamicResource BorderBrush}"
                                       Opacity="0.5" />
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="说明与备注" />

                            <TextBlock Margin="0,0,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="描述" />
                            <TextBox x:Name="TextBoxDescription"
                                     Height="60"
                                     Padding="8,6"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MaxLength="256" />

                            <TextBlock Margin="0,10,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="备注" />
                            <TextBox x:Name="TextBoxRemark"
                                     Height="52"
                                     Padding="8,6"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MaxLength="256" />

                            <TextBlock x:Name="TextBlockError"
                                       Margin="0,10,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource DangerBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 底部按钮 -->
                    <Border Grid.Row="2"
                            Padding="20,12"
                            CornerRadius="0,0,13,13"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Width="80"
                                    Height="34"
                                    Click="ButtonCancel_OnClick"
                                    Content="取消" />
                            <Button Width="80"
                                    Height="34"
                                    Margin="10,0,0,0"
                                    Click="ButtonSave_OnClick"
                                    Content="保存" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>