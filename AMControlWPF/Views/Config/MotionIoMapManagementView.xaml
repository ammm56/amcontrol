<UserControl x:Class="AMControlWPF.Views.Config.MotionIoMapManagementView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Padding="12,8"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="False">

                <!-- 左侧：标题 -->
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="IO 映射配置" />

                <!-- 右侧：操作按钮 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button MinWidth="72"
                            Margin="0,0,8,0"
                            Click="ButtonRefresh_OnClick"
                            Content="刷新" />
                    <Button MinWidth="88"
                            Click="ButtonAdd_OnClick"
                            Content="+ 新增" />
                </StackPanel>

                <!-- 中部：控制卡过滤 + IO类型切换 -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">

                    <!-- DI / DO 类型切换 -->
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ButtonFilterAll"
                                Tag="All"
                                Width="46"
                                Height="28"
                                Click="ButtonFilter_OnClick"
                                Content="全部" />
                        <Button x:Name="ButtonFilterDI"
                                Tag="DI"
                                Width="40"
                                Height="28"
                                Margin="4,0,0,0"
                                Click="ButtonFilter_OnClick"
                                Content="DI" />
                        <Button x:Name="ButtonFilterDO"
                                Tag="DO"
                                Width="40"
                                Height="28"
                                Margin="4,0,0,0"
                                Click="ButtonFilter_OnClick"
                                Content="DO" />
                    </StackPanel>

                    <!-- 控制卡过滤下拉 -->
                    <ComboBox x:Name="ComboBoxCardFilter"
                              Width="180"
                              Height="28"
                              Margin="12,0,0,0"
                              VerticalContentAlignment="Center"
                              SelectionChanged="ComboBoxCardFilter_OnSelectionChanged" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主体区 -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：IO 映射列表 -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="True">
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="IO 点位列表" />
                        <TextBlock DockPanel.Dock="Right"
                                   FontSize="11"
                                   Opacity="0.5"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="{Binding FilteredItems.Count, StringFormat='共 {0} 条'}" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ListBox x:Name="ListBoxIoMaps"
                                 ItemsSource="{Binding FilteredItems}"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 SelectionChanged="ListBoxIoMaps_OnSelectionChanged">

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!-- 紧凑型 IO 列表卡片 -->
                                    <Border CornerRadius="6"
                                            BorderThickness="1"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- 主行：类型徽标 + 名称 + 逻辑位 -->
                                            <DockPanel Grid.Row="0" Margin="10,7,10,4" LastChildFill="True">
                                                <!-- IO 类型徽标 -->
                                                <Border DockPanel.Dock="Left"
                                                        Padding="5,1"
                                                        CornerRadius="3"
                                                        Margin="0,0,7,0"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource SecondaryTextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IoType}" Value="DI">
                                                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IoType}" Value="DO">
                                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="9"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="{Binding IoType}" />
                                                </Border>

                                                <!-- 逻辑位号（右对齐） -->
                                                <TextBlock DockPanel.Dock="Right"
                                                           FontSize="10"
                                                           Opacity="0.45"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Text="{Binding LogicalBit, StringFormat='L#{0}'}" />

                                                <!-- 名称 -->
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Text="{Binding Name}" />
                                            </DockPanel>

                                            <!-- 次行：硬件信息条 -->
                                            <Border Grid.Row="1"
                                                    Padding="10,4"
                                                    CornerRadius="0,0,6,6"
                                                    Background="{DynamicResource RegionBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,1,0,0">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               Text="{Binding CardId, StringFormat='卡 #{0}'}" />
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Margin="8,0,0,0"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               Text="{Binding Core, StringFormat='核 {0}'}" />
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Margin="8,0,0,0"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               Text="{Binding HardwareBit, StringFormat='Bit {0}'}" />
                                                    <TextBlock DockPanel.Dock="Right" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="○ 禁用" />
                                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                        <Setter Property="Text" Value="● 启用" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DockPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 右侧：详情面板 -->
            <Grid Grid.Column="2">

                <!-- 无选中占位 -->
                <Border x:Name="BorderNoSelection"
                        CornerRadius="8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center" FontSize="28" Opacity="0.2" Text="⇅" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Opacity="0.4"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="请选择左侧 IO 点位查看详情" />
                    </StackPanel>
                </Border>

                <!-- 有选中时的详情 -->
                <Border x:Name="BorderDetailContent"
                        CornerRadius="8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Row 0：标题栏 -->
                        <Border Grid.Row="0"
                                Padding="14,10"
                                CornerRadius="8,8,0,0"
                                Background="{DynamicResource RegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Height="30"
                                            Padding="14,0"
                                            Click="ButtonDelete_OnClick"
                                            Content="删除" />
                                    <Button Margin="8,0,0,0" 
                                            Height="30"
                                            Padding="14,0"
                                            Click="ButtonEdit_OnClick"
                                            Content="✏  编辑" />
                                </StackPanel>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding SelectedItem.Name, FallbackValue='—'}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="11"
                                               Opacity="0.6"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding SelectedItem.Remark, FallbackValue='—'}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Row 1：Shield 摘要行（DI/DO 显示不同颜色） -->
                        <Border Grid.Row="1"
                                Padding="14,8"
                                Background="{DynamicResource RegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <WrapPanel Orientation="Horizontal">
                                <!-- DI 逻辑位 Shield -->
                                <hc:Shield Margin="0,0,8,4"
                                           Subject="DI 输入"
                                           Status="{Binding SelectedItem.LogicalBit, StringFormat='L#{0}', FallbackValue='—'}"
                                           Color="{DynamicResource PrimaryBrush}">
                                    <hc:Shield.Style>
                                        <Style TargetType="hc:Shield">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem.IoType}" Value="DI">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </hc:Shield.Style>
                                </hc:Shield>
                                <!-- DO 逻辑位 Shield -->
                                <hc:Shield Margin="0,0,8,4"
                                           Subject="DO 输出"
                                           Status="{Binding SelectedItem.LogicalBit, StringFormat='L#{0}', FallbackValue='—'}"
                                           Color="{DynamicResource WarningBrush}">
                                    <hc:Shield.Style>
                                        <Style TargetType="hc:Shield">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem.IoType}" Value="DO">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </hc:Shield.Style>
                                </hc:Shield>
                                <!-- 控制卡 Shield -->
                                <hc:Shield Margin="0,0,8,4"
                                           Subject="控制卡"
                                           Status="{Binding SelectedItemCardDisplay, FallbackValue='—'}"
                                           Color="{DynamicResource SuccessBrush}" />
                                <!-- 扩展模块 Shield（仅扩展时显示） -->
                                <hc:Shield Margin="0,0,0,4"
                                           Subject="扩展模块"
                                           Status="EXT"
                                           Color="{DynamicResource DangerBrush}">
                                    <hc:Shield.Style>
                                        <Style TargetType="hc:Shield">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem.IsExtModule}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </hc:Shield.Style>
                                </hc:Shield>
                            </WrapPanel>
                        </Border>

                        <!-- Row 2：两列字段详情 -->
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="14,8,14,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 左列：基础标识 -->
                                <StackPanel Grid.Column="0">
                                    <hc:Divider Margin="0,4,0,0" Content="基础标识" />

                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="IO 类型" />
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DetailValueStyle}">
                                                <Setter Property="Text" Value="{Binding SelectedItem.IoType, FallbackValue='—'}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedItem.IoType}" Value="DI">
                                                        <Setter Property="Text" Value="DI（数字输入）" />
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedItem.IoType}" Value="DO">
                                                        <Setter Property="Text" Value="DO（数字输出）" />
                                                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="逻辑位号" />
                                    <TextBlock Style="{StaticResource DetailValueStyle}"
                                               Text="{Binding SelectedItem.LogicalBit, StringFormat='L#{0}', FallbackValue='—'}" />

                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="名称" />
                                    <TextBlock Style="{StaticResource DetailValueStyle}"
                                               FontWeight="SemiBold"
                                               Text="{Binding SelectedItem.Name, FallbackValue='—'}" />

                                    <hc:Divider Margin="0,10,0,0" Content="状态" />

                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="启用状态" />
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DetailValueStyle}">
                                                <Setter Property="Text" Value="○ 已禁用" />
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedItem.IsEnabled}" Value="True">
                                                        <Setter Property="Text" Value="● 已启用" />
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="排序号" />
                                    <TextBlock Style="{StaticResource DetailValueStyle}"
                                               Text="{Binding SelectedItem.SortOrder, FallbackValue='—'}" />
                                </StackPanel>

                                <!-- 右列：物理映射 -->
                                <StackPanel Grid.Column="2">
                                    <hc:Divider Margin="0,4,0,0" Content="物理映射" />

                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="所属控制卡" />
                                    <TextBlock Style="{StaticResource DetailValueStyle}"
                                               Text="{Binding SelectedItemCardDisplay, FallbackValue='—'}" />

                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="所属内核" />
                                    <TextBlock Style="{StaticResource DetailValueStyle}"
                                               Text="{Binding SelectedItem.Core, StringFormat='核 {0}', FallbackValue='—'}" />

                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="硬件位号" />
                                    <TextBlock Style="{StaticResource DetailValueStyle}"
                                               Text="{Binding SelectedItem.HardwareBit, StringFormat='Bit {0}', FallbackValue='—'}" />

                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="是否扩展模块" />
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DetailValueStyle}">
                                                <Setter Property="Text" Value="否（板载 IO）" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedItem.IsExtModule}" Value="True">
                                                        <Setter Property="Text" Value="是（扩展模块）" />
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <hc:Divider Margin="0,10,0,0" Content="备注" />

                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="备注" />
                                    <TextBlock Style="{StaticResource DetailValueStyle}"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedItem.Remark, FallbackValue='—'}" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部状态栏 -->
        <TextBlock Grid.Row="2"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Opacity="0.55"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Text="{Binding StatusText}" />
    </Grid>
</UserControl>