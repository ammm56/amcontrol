<hc:GlowWindow x:Class="AMControlWPF.Views.Config.AxisParamAddDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               mc:Ignorable="d"
               Title="新增轴运行参数"
               Width="520"
               Height="680"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               Background="{DynamicResource RegionBrush}">

    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="16">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ─── 标题栏 ─── -->
                    <Border Grid.Row="0"
                            Padding="20,14"
                            CornerRadius="14,14,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="新增轴运行参数" />
                            <TextBlock x:Name="TextBlockAxisContext"
                                       Margin="10,0,0,0"
                                       FontSize="13"
                                       Opacity="0.6"
                                       VerticalAlignment="Bottom"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- ─── 内容区 ─── -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="20,16,20,8"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- 参数名（代码名） + 显示名称 -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="12"
                                               Opacity="0.6"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="参数名 *（英文代码名）" />
                                    <TextBox x:Name="TextBoxParamName"
                                             Height="36"
                                             FontSize="13"
                                             VerticalContentAlignment="Center"
                                             MaxLength="60" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="12"
                                               Opacity="0.6"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="显示名称 *" />
                                    <TextBox x:Name="TextBoxDisplayName"
                                             Height="36"
                                             FontSize="13"
                                             VerticalContentAlignment="Center"
                                             MaxLength="50" />
                                </StackPanel>
                            </Grid>

                            <!-- 分组 + 类型 -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="12"
                                               Opacity="0.6"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="分组 *" />
                                    <ComboBox x:Name="ComboBoxGroup"
                                              Height="36"
                                              VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="硬件信号" Tag="Hardware" />
                                        <ComboBoxItem Content="单位换算" Tag="Scale" />
                                        <ComboBoxItem Content="运动参数" Tag="Motion" IsSelected="True" />
                                        <ComboBoxItem Content="回零参数" Tag="Home" />
                                        <ComboBoxItem Content="软件限位" Tag="SoftLimit" />
                                        <ComboBoxItem Content="使能时序" Tag="Timing" />
                                        <ComboBoxItem Content="安全联动" Tag="Safety" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="12"
                                               Opacity="0.6"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="类型 *" />
                                    <ComboBox x:Name="ComboBoxType"
                                              Height="36"
                                              VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="小数（Double）" Tag="Double" IsSelected="True" />
                                        <ComboBoxItem Content="整数（Int32）" Tag="Int32" />
                                        <ComboBoxItem Content="短整数（Int16）" Tag="Int16" />
                                        <ComboBoxItem Content="布尔（Bool）" Tag="Bool" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- 初始值 + 默认值 -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="12"
                                               Opacity="0.6"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="初始值 *" />
                                    <TextBox x:Name="TextBoxSetValue"
                                             Height="36"
                                             FontSize="13"
                                             VerticalContentAlignment="Center"
                                             MaxLength="20"
                                             Text="0" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="12"
                                               Opacity="0.6"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="默认值 *" />
                                    <TextBox x:Name="TextBoxDefaultValue"
                                             Height="36"
                                             FontSize="13"
                                             VerticalContentAlignment="Center"
                                             MaxLength="20"
                                             Text="0" />
                                </StackPanel>
                            </Grid>

                            <!-- 最小值 + 最大值 -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="12"
                                               Opacity="0.6"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="最小值（0=不限）" />
                                    <TextBox x:Name="TextBoxMinValue"
                                             Height="36"
                                             FontSize="13"
                                             VerticalContentAlignment="Center"
                                             MaxLength="20"
                                             Text="0" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="12"
                                               Opacity="0.6"
                                               Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="最大值（0=不限）" />
                                    <TextBox x:Name="TextBoxMaxValue"
                                             Height="36"
                                             FontSize="13"
                                             VerticalContentAlignment="Center"
                                             MaxLength="20"
                                             Text="0" />
                                </StackPanel>
                            </Grid>

                            <!-- 单位 -->
                            <TextBlock FontSize="12"
                                       Opacity="0.6"
                                       Margin="0,0,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="单位（无单位填 none）" />
                            <TextBox x:Name="TextBoxUnit"
                                     Height="36"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     MaxLength="20"
                                     Margin="0,0,0,14" />

                            <!-- 说明 -->
                            <TextBlock FontSize="12"
                                       Opacity="0.6"
                                       Margin="0,0,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="说明（可选）" />
                            <TextBox x:Name="TextBoxDescription"
                                     MinHeight="60"
                                     FontSize="12"
                                     VerticalContentAlignment="Top"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MaxLength="200"
                                     Padding="8,6"
                                     Margin="0,0,0,12" />

                            <!-- 校验错误提示 -->
                            <Border x:Name="BorderError"
                                    Padding="10,7"
                                    CornerRadius="4"
                                    Background="#FFF3E0"
                                    BorderBrush="#FFCC80"
                                    BorderThickness="1"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="TextBlockError"
                                           FontSize="12"
                                           Foreground="#E65100"
                                           TextWrapping="Wrap" />
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ─── 按钮区 ─── -->
                    <Border Grid.Row="2"
                            Padding="16,12"
                            CornerRadius="0,0,14,14"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button MinWidth="80"
                                    Margin="0,0,8,0"
                                    Click="ButtonCancel_OnClick"
                                    Content="取 消" />
                            <Button MinWidth="100"
                                    Click="ButtonSave_OnClick"
                                    Content="确认新增" />
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>
        </Grid>
    </Grid>

</hc:GlowWindow>