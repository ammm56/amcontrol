<hc:GlowWindow x:Class="AMControlWPF.Views.Config.AxisParamEditDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               mc:Ignorable="d"
               Title="修改参数值"
               Width="460"
               Height="460"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               Background="{DynamicResource RegionBrush}">

    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="16">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ─── 标题栏 ─── -->
                    <Border Grid.Row="0"
                            Padding="20,14"
                            CornerRadius="14,14,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="修改参数值" />
                            <TextBlock Margin="10,0,0,0"
                                       FontSize="13"
                                       Opacity="0.6"
                                       VerticalAlignment="Bottom"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding ParamDisplayName, StringFormat='— {0}'}" />
                        </StackPanel>
                    </Border>

                    <!-- ─── 内容区 ─── -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="20,16,20,8"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- 参数元数据标签 -->
                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <hc:Shield Margin="0,0,6,4"
                                           Subject="类型"
                                           Status="{Binding TypeLabel}"
                                           Color="#1976D2" />
                                <hc:Shield Margin="0,0,6,4"
                                           Subject="单位"
                                           Status="{Binding Unit}"
                                           Color="#455A64" />
                                <hc:Shield Margin="0,0,6,4"
                                           Subject="默认值"
                                           Status="{Binding ParamDefaultValueText}"
                                           Color="#388E3C" />
                                <hc:Shield Margin="0,0,0,4"
                                           Subject="允许范围"
                                           Status="{Binding RangeText}"
                                           Color="#F57C00" />
                            </WrapPanel>

                            <!-- 参数说明 -->
                            <TextBlock FontSize="12"
                                       Opacity="0.8"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding Description}" />

                            <!-- 值含义（非空时才显示） -->
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="11"
                                       Opacity="0.65"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding ValueDescription}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ValueDescription}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Separator Margin="0,12,0,12"
                                       Background="{DynamicResource BorderBrush}" />

                            <!-- 当前值（只读展示） -->
                            <TextBlock FontSize="12"
                                       Opacity="0.6"
                                       Margin="0,0,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="当前值" />
                            <Border Padding="10,7"
                                    CornerRadius="4"
                                    Margin="0,0,0,14"
                                    Background="{DynamicResource SecondaryRegionBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <TextBlock x:Name="TextBlockCurrentValue"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                            </Border>

                            <!-- 新值输入 -->
                            <TextBlock FontSize="12"
                                       Opacity="0.6"
                                       Margin="0,0,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="新值" />
                            <TextBox x:Name="TextBoxNewValue"
                                     Height="36"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     MaxLength="32" />

                            <!-- 校验错误提示 -->
                            <Border x:Name="BorderError"
                                    Margin="0,8,0,0"
                                    Padding="10,7"
                                    CornerRadius="4"
                                    Background="#FFF3E0"
                                    BorderBrush="#FFCC80"
                                    BorderThickness="1"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="TextBlockError"
                                           FontSize="12"
                                           Foreground="#E65100"
                                           TextWrapping="Wrap" />
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ─── 按钮区 ─── -->
                    <Border Grid.Row="2"
                            Padding="16,12"
                            CornerRadius="0,0,14,14"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button MinWidth="80"
                                    Margin="0,0,8,0"
                                    Click="ButtonCancel_OnClick"
                                    Content="取 消" />
                            <Button MinWidth="100"
                                    Click="ButtonConfirm_OnClick"
                                    Content="确认修改" />
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>
        </Grid>
    </Grid>

</hc:GlowWindow>