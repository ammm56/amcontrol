<hc:GlowWindow x:Class="AMControlWPF.Views.Config.StackLightEditDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               Title="灯塔配置"
               Width="520" Height="620"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               Background="{DynamicResource RegionBrush}">
    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />
        <Grid Margin="16">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16" CornerRadius="14,14,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="TextBlockTitle" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Text="新增灯塔" />
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="20,12,20,8"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- ── 基础标识 ── -->
                            <TextBlock Margin="0,0,0,8" FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Text="基础标识" />

                            <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="内部名称 *" />
                            <TextBox x:Name="TextBoxName" Height="36" VerticalContentAlignment="Center" MaxLength="64" />

                            <TextBlock Margin="0,10,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="显示名称" />
                            <TextBox x:Name="TextBoxDisplayName" Height="36" VerticalContentAlignment="Center" MaxLength="64" />

                            <!-- ── 输出位映射 ── -->
                            <Rectangle Height="1" Margin="0,14,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <TextBlock Margin="0,0,0,8" FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="DO 输出位映射（从已配置 IO 点位中选择，不使用请选「── 不配置 ──」）" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="红灯 (DO)" />
                                    <ComboBox x:Name="CbRedOutputBit" Height="36" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="黄灯 (DO)" />
                                    <ComboBox x:Name="CbYellowOutputBit" Height="36" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="绿灯 (DO)" />
                                    <ComboBox x:Name="CbGreenOutputBit" Height="36" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="蓝灯 (DO)" />
                                    <ComboBox x:Name="CbBlueOutputBit" Height="36" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Margin="0,10,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="蜂鸣器 (DO)" />
                            <ComboBox x:Name="CbBuzzerOutputBit" Height="36" />

                            <!-- ── 控制参数 ── -->
                            <Rectangle Height="1" Margin="0,14,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <TextBlock Margin="0,0,0,8" FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Text="控制参数" />

                            <CheckBox x:Name="CheckBoxEnableBuzzerOnWarning"  Margin="0,0,0,6"  Content="警告状态默认带蜂鸣器" />
                            <CheckBox x:Name="CheckBoxEnableBuzzerOnAlarm"    Margin="0,0,0,6"  Content="报警状态默认带蜂鸣器" />
                            <CheckBox x:Name="CheckBoxAllowMultiSegmentOn"    Margin="0,0,0,10" Content="允许多颜色同时点亮" />

                            <!-- ── 高级设置 ── -->
                            <Rectangle Height="1" Margin="0,4,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="排序号" />
                                    <TextBox x:Name="TextBoxSortOrder" Height="36" VerticalContentAlignment="Center" MaxLength="6" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                    <CheckBox x:Name="CheckBoxIsEnabled" Content="启用" />
                                </StackPanel>
                            </Grid>

                            <!-- ── 说明 ── -->
                            <Rectangle Height="1" Margin="0,14,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="描述说明" />
                            <TextBox x:Name="TextBoxDescription" Height="36" VerticalContentAlignment="Center" MaxLength="256" />

                            <TextBlock Margin="0,10,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="备注" />
                            <TextBox x:Name="TextBoxRemark" Height="36" VerticalContentAlignment="Center" MaxLength="256" />

                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Padding="20,12" CornerRadius="0,0,14,14"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TextBlockError" Grid.Row="0" Margin="0,0,0,8"
                                       Foreground="{DynamicResource DangerBrush}"
                                       TextWrapping="Wrap" Visibility="Collapsed" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button MinWidth="80" Margin="0,0,8,0" Click="ButtonCancel_OnClick" Content="取消" />
                                <Button MinWidth="80" Style="{StaticResource ButtonSuccess}" Click="ButtonSave_OnClick" Content="保存" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>