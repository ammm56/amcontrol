<UserControl x:Class="AMControlWPF.Views.Config.MotionCardManagementView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Padding="12,10"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            DockPanel.Dock="Left">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="控制卡配置" />
                </StackPanel>
                <WrapPanel HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right">
                    <Button MinWidth="72"
                            Margin="0,0,8,0"
                            Click="ButtonRefresh_OnClick"
                            Content="刷新" />
                    <Button MinWidth="88"
                            Click="ButtonAdd_OnClick"
                            Content="+ 新增控制卡" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- 主体区 -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：控制卡列表 -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="控制卡列表" />

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ListBox x:Name="ListBoxCards"
                                 ItemsSource="{Binding Items}"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 SelectionChanged="ListBoxCards_OnSelectionChanged">

                            <!-- 透明容器：视觉全部交由 DataTemplate 内 Border 处理 -->
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Effect="{StaticResource EffectShadow2}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="4" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- 顶部类型色带 -->
                                            <Border Grid.Row="0" CornerRadius="8,8,0,0">
                                            </Border>

                                            <!-- 主体内容 -->
                                            <StackPanel Grid.Row="1" Margin="10,8,10,8">
                                                <DockPanel LastChildFill="False">
                                                    <!-- 类型徽标 -->
                                                    <Border DockPanel.Dock="Left" Padding="4,1" CornerRadius="3">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{DynamicResource SecondaryTextBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CardType}" Value="10">
                                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding CardType}" Value="20">
                                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding CardType}" Value="90">
                                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="OTHER" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding CardType}" Value="10">
                                                                            <Setter Property="Text" Value="GOOGO" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding CardType}" Value="20">
                                                                            <Setter Property="Text" Value="LEISAI" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding CardType}" Value="90">
                                                                            <Setter Property="Text" Value="VIRTUAL" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <!-- 卡号 -->
                                                    <TextBlock DockPanel.Dock="Right"
                                                               FontSize="10"
                                                               Opacity="0.5"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               Text="{Binding CardId, StringFormat='#{0}'}" />
                                                </DockPanel>

                                                <TextBlock Margin="0,6,0,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Text="{Binding DisplayName}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           FontSize="11"
                                                           Opacity="0.6"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Text="{Binding Name}" />
                                            </StackPanel>

                                            <!-- 底部状态栏 -->
                                            <Border Grid.Row="2"
                                                    Padding="10,5"
                                                    CornerRadius="0,0,8,8"
                                                    Background="{DynamicResource RegionBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,1,0,0">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               Text="{Binding CoreNumber, StringFormat='核: {0}'}" />
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Margin="8,0,0,0"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               Text="{Binding AxisCountNumber, StringFormat='轴: {0}'}" />
                                                    <TextBlock DockPanel.Dock="Right" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="○ 禁用" />
                                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                        <Setter Property="Text" Value="● 启用" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DockPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 右侧：详情面板 -->
            <Grid Grid.Column="2">

                <!-- 无选中时占位 -->
                <Border x:Name="BorderNoSelection"
                        CornerRadius="8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="28"
                                   Opacity="0.2"
                                   Text="☰" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Opacity="0.4"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="请选择左侧控制卡查看详情" />
                    </StackPanel>
                </Border>

                <!-- 有选中时的详情内容 -->
                <Border x:Name="BorderDetailContent"
                        CornerRadius="8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 标题栏：名称 + 操作按钮 -->
                        <Border Grid.Row="0"
                                Padding="14,10"
                                CornerRadius="8,8,0,0"
                                Background="{DynamicResource RegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button x:Name="ButtonDelete"
                                            Height="30"
                                            Padding="14,0"
                                            Click="ButtonDelete_OnClick"
                                            Content="删除" />
                                    <Button x:Name="ButtonEdit"
                                            Margin="8,0,0,0"
                                            Height="30"
                                            Padding="14,0"
                                            Click="ButtonEdit_OnClick"
                                            Content="✏  编辑" />
                                </StackPanel>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding SelectedItem.DisplayName, FallbackValue='—'}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="11"
                                               Opacity="0.6"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding SelectedItem.Name, FallbackValue='—'}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- 详情字段：两列，无滚动条 -->
                        <Grid Grid.Row="1" Margin="14,8,14,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 左列：基础标识 + 状态与排序 -->
                            <StackPanel Grid.Column="0">
                                <hc:Divider Margin="0,4,0,0" Content="基础标识" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="卡号 (CardId)" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.CardId, FallbackValue='—'}" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="控制卡类型" />
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" >
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="OTHER" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem.CardType}" Value="10">
                                                    <Setter Property="Text" Value="GOOGO" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedItem.CardType}" Value="20">
                                                    <Setter Property="Text" Value="LEISAI" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedItem.CardType}" Value="90">
                                                    <Setter Property="Text" Value="VIRTUAL" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!--<TextBlock Style="{StaticResource DetailValueStyle}">
                                </TextBlock>-->

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="显示名称" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectedItem.DisplayName, FallbackValue='—'}" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="内部名称" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.Name, FallbackValue='—'}" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="驱动识别键" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.DriverKey, FallbackValue='—'}" />

                                <hc:Divider Margin="0,10,0,0" Content="状态与排序" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="启用状态" />
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DetailValueStyle}">
                                            <Setter Property="Text" Value="○ 已禁用" />
                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem.IsEnabled}" Value="True">
                                                    <Setter Property="Text" Value="● 已启用" />
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="排序号" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.SortOrder, FallbackValue='—'}" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="更新时间" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.UpdateTime, StringFormat='yyyy-MM-dd HH:mm:ss', FallbackValue='—'}" />
                            </StackPanel>

                            <!-- 右列：初始化参数 + 说明与备注 -->
                            <StackPanel Grid.Column="2">
                                <hc:Divider Margin="0,4,0,0" Content="初始化参数" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="内核数量" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.CoreNumber, FallbackValue='—'}" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="支持轴总数" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.AxisCountNumber, FallbackValue='—'}" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="打开模式参数" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.ModeParam, FallbackValue='—'}" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="初始化顺序" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.InitOrder, FallbackValue='—'}" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="扩展模块" />
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DetailValueStyle}">
                                            <Setter Property="Text" Value="否" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem.UseExtModule}" Value="True">
                                                    <Setter Property="Text" Value="是（有扩展 IO 模块）" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <hc:Divider Margin="0,10,0,0" Content="说明与备注" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="描述" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.Description, FallbackValue='—'}" />

                                <TextBlock Style="{StaticResource DetailLabelStyle}" Text="备注" />
                                <TextBlock Style="{StaticResource DetailValueStyle}"
                                           Text="{Binding SelectedItem.Remark, FallbackValue='—'}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部状态栏 -->
        <TextBlock Grid.Row="2"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Opacity="0.55"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Text="{Binding StatusText}" />
    </Grid>
</UserControl>