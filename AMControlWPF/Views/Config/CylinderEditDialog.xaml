<hc:GlowWindow x:Class="AMControlWPF.Views.Config.CylinderEditDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               Title="气缸配置"
               Width="520"
               Height="720"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               Background="{DynamicResource RegionBrush}">
    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />
        <Grid Margin="16">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0"
                            Padding="20,16"
                            CornerRadius="14,14,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock x:Name="TextBlockTitle"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="新增气缸" />
                    </Border>

                    <!-- 表单区 -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="20,12,20,8"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- ── 基础标识 ── -->
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="基础标识" />

                            <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="内部名称 *" />
                            <TextBox x:Name="TextBoxName" Height="36" VerticalContentAlignment="Center" MaxLength="64" />

                            <TextBlock Margin="0,10,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="显示名称" />
                            <TextBox x:Name="TextBoxDisplayName" Height="36" VerticalContentAlignment="Center" MaxLength="64" />

                            <TextBlock Margin="0,10,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="驱动模式" />
                            <ComboBox x:Name="ComboBoxDriveMode" Height="36" SelectionChanged="ComboBoxDriveMode_OnSelectionChanged">
                                <ComboBoxItem Content="Double（双线圈）" Tag="Double" />
                                <ComboBoxItem Content="Single（单线圈）" Tag="Single" />
                            </ComboBox>

                            <!-- ── IO 映射 ── -->
                            <Rectangle Height="1" Margin="0,14,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="IO 映射（填写 motion_io_map 中的逻辑位号，空白=不使用）" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="伸出输出位 (DO) *" />
                                    <TextBox x:Name="TextBoxExtendOutputBit" Height="36" VerticalContentAlignment="Center" MaxLength="6" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="缩回输出位 (DO)" />
                                    <TextBox x:Name="TextBoxRetractOutputBit" Height="36" VerticalContentAlignment="Center" MaxLength="6" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="伸出反馈位 (DI)" />
                                    <TextBox x:Name="TextBoxExtendFeedbackBit" Height="36" VerticalContentAlignment="Center" MaxLength="6" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="缩回反馈位 (DI)" />
                                    <TextBox x:Name="TextBoxRetractFeedbackBit" Height="36" VerticalContentAlignment="Center" MaxLength="6" />
                                </StackPanel>
                            </Grid>

                            <!-- ── 控制参数 ── -->
                            <Rectangle Height="1" Margin="0,14,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="控制参数" />

                            <CheckBox x:Name="CheckBoxUseFeedbackCheck" Margin="0,0,0,10" Content="启用反馈校验" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="伸出超时 (ms)" />
                                    <TextBox x:Name="TextBoxExtendTimeoutMs" Height="36" VerticalContentAlignment="Center" MaxLength="8" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="缩回超时 (ms)" />
                                    <TextBox x:Name="TextBoxRetractTimeoutMs" Height="36" VerticalContentAlignment="Center" MaxLength="8" />
                                </StackPanel>
                            </Grid>

                            <!-- ── 高级设置 ── -->
                            <Rectangle Height="1" Margin="0,14,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="高级设置" />

                            <CheckBox x:Name="CheckBoxAllowBothOff" Margin="0,0,0,6" Content="允许双输出同时关闭（AllowBothOff）" />
                            <CheckBox x:Name="CheckBoxAllowBothOn" Margin="0,0,0,10" Content="允许双输出同时导通（AllowBothOn，一般禁用）" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="排序号" />
                                    <TextBox x:Name="TextBoxSortOrder" Height="36" VerticalContentAlignment="Center" MaxLength="6" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                    <CheckBox x:Name="CheckBoxIsEnabled" Content="启用" />
                                </StackPanel>
                            </Grid>

                            <!-- ── 说明 ── -->
                            <Rectangle Height="1" Margin="0,14,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="描述说明" />
                            <TextBox x:Name="TextBoxDescription" Height="36" VerticalContentAlignment="Center" MaxLength="256" />

                            <TextBlock Margin="0,10,0,4" Foreground="{DynamicResource PrimaryTextBrush}" Text="备注" />
                            <TextBox x:Name="TextBoxRemark" Height="36" VerticalContentAlignment="Center" MaxLength="256" />

                        </StackPanel>
                    </ScrollViewer>

                    <!-- 页脚 -->
                    <Border Grid.Row="2"
                            Padding="20,12"
                            CornerRadius="0,0,14,14"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TextBlockError"
                                       Grid.Row="0"
                                       Margin="0,0,0,8"
                                       Foreground="{DynamicResource DangerBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button MinWidth="80"
                                        Margin="0,0,8,0"
                                        Click="ButtonCancel_OnClick"
                                        Content="取消" />
                                <Button MinWidth="80"
                                        Style="{StaticResource ButtonSuccess}"
                                        Click="ButtonSave_OnClick"
                                        Content="保存" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>