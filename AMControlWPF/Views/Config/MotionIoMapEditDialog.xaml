<hc:GlowWindow x:Class="AMControlWPF.Views.Config.MotionIoMapEditDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               Title="IO 映射配置"
               Width="500"
               Height="580"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               Background="{DynamicResource RegionBrush}">

    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="16">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0"
                            Padding="20,16"
                            CornerRadius="14,14,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock x:Name="TextBlockTitle"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="新增 IO 映射" />
                    </Border>

                    <!-- 表单区 -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="20,12,20,8"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- ── 基础标识 ── -->
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="基础标识" />

                            <!-- 所属控制卡 + IO 类型 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="所属控制卡 *" />
                                    <ComboBox x:Name="ComboBoxCardId"
                                              Height="36"
                                              SelectionChanged="ComboBoxCardId_OnSelectionChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2" VerticalAlignment="Center">
                                                    <Border Padding="6,2"
                                                            CornerRadius="3"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            Background="{DynamicResource PrimaryBrush}">
                                                        <TextBlock Text="{Binding CardId, StringFormat='#{0}'}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White" />
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" />
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="10" Opacity="0.6" Foreground="{DynamicResource PrimaryTextBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="Text" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="IO 类型 *" />
                                    <ComboBox x:Name="ComboBoxIoType" Height="36">
                                        <ComboBoxItem Content="DI（数字输入）" Tag="DI" />
                                        <ComboBoxItem Content="DO（数字输出）" Tag="DO" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- 逻辑位号 + 名称 -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="逻辑位号 * (≥1)" />
                                    <TextBox x:Name="TextBoxLogicalBit"
                                             Height="36"
                                             VerticalContentAlignment="Center"
                                             MaxLength="5" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="名称 *" />
                                    <TextBox x:Name="TextBoxName"
                                             Height="36"
                                             VerticalContentAlignment="Center"
                                             MaxLength="64" />
                                </StackPanel>
                            </Grid>

                            <!-- ── 物理映射 ── -->
                            <Rectangle Height="1" Margin="0,14,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="物理映射" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 所属内核（依赖所选控制卡动态生成） -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="所属内核 (Core)" />
                                    <ComboBox x:Name="ComboBoxCore" Height="36" />
                                </StackPanel>

                                <!-- 硬件位号 -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="硬件位号 (HardwareBit)" />
                                    <TextBox x:Name="TextBoxHardwareBit"
                                             Height="36"
                                             VerticalContentAlignment="Center"
                                             MaxLength="5" />
                                </StackPanel>
                            </Grid>

                            <CheckBox x:Name="CheckBoxIsExtModule"
                                      Margin="0,10,0,0"
                                      Content="是扩展模块 IO（非板载，通过 IO 扩展模块接入）"
                                      Foreground="{DynamicResource PrimaryTextBrush}" />

                            <!-- ── 状态与排序 ── -->
                            <Rectangle Height="1" Margin="0,14,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="状态与排序" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="CheckBoxIsEnabled"
                                          Grid.Column="0"
                                          VerticalAlignment="Center"
                                          Content="启用此 IO 点位"
                                          Foreground="{DynamicResource PrimaryTextBrush}" />
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="排序号" />
                                    <TextBox x:Name="TextBoxSortOrder"
                                             Height="36"
                                             VerticalContentAlignment="Center"
                                             MaxLength="4" />
                                </StackPanel>
                            </Grid>

                            <!-- ── 备注 ── -->
                            <Rectangle Height="1" Margin="0,14,0,10" Fill="{DynamicResource BorderBrush}" Opacity="0.5" />
                            <TextBlock Margin="0,0,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="备注" />
                            <TextBox x:Name="TextBoxRemark"
                                     Height="52"
                                     Padding="8,6"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MaxLength="256" />

                            <TextBlock x:Name="TextBlockError"
                                       Margin="0,10,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource DangerBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 底部按钮 -->
                    <Border Grid.Row="2"
                            Padding="20,12"
                            CornerRadius="0,0,13,13"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Width="80" Height="34" Click="ButtonCancel_OnClick" Content="取消" />
                            <Button Width="80" Height="34" Margin="10,0,0,0" Click="ButtonSave_OnClick" Content="保存" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>