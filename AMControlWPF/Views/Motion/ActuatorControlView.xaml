<UserControl x:Class="AMControlWPF.Views.Motion.ActuatorControlView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="RootToolbarRow" Height="Auto" />
            <RowDefinition x:Name="RootContentRow" Height="*" />
            <RowDefinition x:Name="RootStatusRow" Height="40" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Padding="12,8"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="执行器控制" />

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button MinWidth="72"
                            Command="{Binding RefreshCommand}"
                            Content="刷新" />
                </StackPanel>

                <!-- 类型筛选按钮 -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <Button Width="46"
                            Height="28"
                            Margin="0,0,4,0"
                            Command="{Binding SetTypeFilterCommand}"
                            CommandParameter="All"
                            Content="全部" />
                    <Button Width="46"
                            Height="28"
                            Margin="0,0,4,0"
                            Command="{Binding SetTypeFilterCommand}"
                            CommandParameter="Cylinder"
                            Content="气缸" />
                    <Button Width="46"
                            Height="28"
                            Margin="0,0,4,0"
                            Command="{Binding SetTypeFilterCommand}"
                            CommandParameter="Gripper"
                            Content="夹爪" />
                    <Button Width="46"
                            Height="28"
                            Margin="0,0,4,0"
                            Command="{Binding SetTypeFilterCommand}"
                            CommandParameter="Vacuum"
                            Content="真空" />
                    <Button Width="46"
                            Height="28"
                            Command="{Binding SetTypeFilterCommand}"
                            CommandParameter="StackLight"
                            Content="灯塔" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主内容区：三栏布局 -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：执行器列表 -->
            <Border Grid.Column="0"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="12,8"
                            CornerRadius="8,8,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="执行器列表" />
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             Padding="6">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Padding="{TemplateBinding Padding}"
                                                    Margin="{TemplateBinding Margin}"
                                                    CornerRadius="5"
                                                    Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 类型徽标 -->
                                    <Border Grid.Column="0"
                                            Padding="5,2"
                                            CornerRadius="3"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#607D8B" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActuatorType}" Value="Cylinder">
                                                        <Setter Property="Background" Value="#1565C0" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActuatorType}" Value="Gripper">
                                                        <Setter Property="Background" Value="#6A1B9A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActuatorType}" Value="Vacuum">
                                                        <Setter Property="Background" Value="#00695C" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActuatorType}" Value="StackLight">
                                                        <Setter Property="Background" Value="#E65100" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Text="{Binding TypeDisplay}" />
                                    </Border>

                                    <!-- 执行器名称 -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="{Binding DisplayName}" />
                                        <TextBlock FontSize="10"
                                                   Opacity="0.55"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="{Binding StateText}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 中间：控制区域 -->
            <Border Grid.Column="2"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">

                <!-- 未选中提示 -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock HorizontalAlignment="Center" FontSize="36" Opacity="0.12" Text="⚙" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="13"
                               Opacity="0.4"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="请选择执行器以操作" />
                </StackPanel>

                <!-- 执行器控制面板（有选中时显示） -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 控制头部：执行器名称 + 状态 -->
                    <Border Grid.Row="0"
                            Padding="16,12"
                            CornerRadius="8,8,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedItem.DisplayName, FallbackValue=—}" />
                                <TextBlock Margin="0,2,0,0"
                                           FontSize="11"
                                           Opacity="0.6"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedItem.Name, FallbackValue=—}" />
                            </StackPanel>

                            <!-- 类型徽标 -->
                            <Border DockPanel.Dock="Right"
                                    Padding="8,4"
                                    CornerRadius="4"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#607D8B" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="Cylinder">
                                                <Setter Property="Background" Value="#1565C0" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="Gripper">
                                                <Setter Property="Background" Value="#6A1B9A" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="Vacuum">
                                                <Setter Property="Background" Value="#00695C" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="StackLight">
                                                <Setter Property="Background" Value="#E65100" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="{Binding SelectedItem.TypeDisplay, FallbackValue=—}" />
                            </Border>
                        </DockPanel>
                    </Border>

                    <!-- 控制按钮区域 -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="16">

                        <StackPanel>
                            <!-- 状态显示区域 -->
                            <Border Padding="12"
                                    Margin="0,0,0,16"
                                    CornerRadius="6"
                                    Background="{DynamicResource SecondaryRegionBrush}">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Opacity="0.7"
                                               Margin="0,0,0,8"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="当前状态" />

                                    <!-- 综合状态文本 -->
                                    <TextBlock FontSize="20"
                                               FontWeight="Bold"
                                               Margin="0,0,0,10"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding SelectedItem.StateText, FallbackValue=—}" />

                                    <!-- 状态指示灯 -->
                                    <WrapPanel>
                                        <!-- 状态A指示灯 -->
                                        <Border Padding="8,4"
                                                Margin="0,0,6,4"
                                                CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#37474F" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem.IsStateA}" Value="True">
                                                            <Setter Property="Background" Value="#2E7D32" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         Margin="0,0,5,0"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#546E7A" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedItem.IsStateA}" Value="True">
                                                                    <Setter Property="Fill" Value="#A5D6A7" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           Text="{Binding SelectedItem.StateALabel, FallbackValue=—}" />
                                            </StackPanel>
                                        </Border>

                                        <!-- 状态B指示灯 -->
                                        <Border Padding="8,4"
                                                Margin="0,0,6,4"
                                                CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#37474F" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem.IsStateB}" Value="True">
                                                            <Setter Property="Background" Value="#2E7D32" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         Margin="0,0,5,0"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#546E7A" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedItem.IsStateB}" Value="True">
                                                                    <Setter Property="Fill" Value="#A5D6A7" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           Text="{Binding SelectedItem.StateBLabel, FallbackValue=—}" />
                                            </StackPanel>
                                        </Border>

                                        <!-- 状态C指示灯（仅灯塔使用） -->
                                        <Border Padding="8,4"
                                                Margin="0,0,6,4"
                                                CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="StackLight">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedItem.IsStateC}" Value="True">
                                                            <Setter Property="Background" Value="#2E7D32" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Background>
                                                <SolidColorBrush Color="#37474F" />
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         Margin="0,0,5,0"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#546E7A" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedItem.IsStateC}" Value="True">
                                                                    <Setter Property="Fill" Value="#A5D6A7" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           Text="{Binding SelectedItem.StateCLabel, FallbackValue=绿}" />
                                            </StackPanel>
                                        </Border>

                                        <!-- 工件检测（夹爪/真空） -->
                                        <Border Padding="8,4"
                                                Margin="0,0,6,4"
                                                CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="Gripper">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="Vacuum">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedItem.HasWorkpiece}" Value="True">
                                                            <Setter Property="Background" Value="#1565C0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Background>
                                                <SolidColorBrush Color="#37474F" />
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         Margin="0,0,5,0"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#546E7A" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedItem.HasWorkpiece}" Value="True">
                                                                    <Setter Property="Fill" Value="#90CAF9" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           Text="工件" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- 气缸控制按钮 -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="Cylinder">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="气缸控制"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Opacity="0.7"
                                           Margin="0,0,0,10"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                <UniformGrid Columns="2" Rows="1">
                                    <Button Height="52"
                                            Margin="0,0,6,0"
                                            Command="{Binding CylinderExtendCommand}"
                                            Content="伸出"
                                            Style="{StaticResource ButtonPrimary}" />
                                    <Button Height="52"
                                            Command="{Binding CylinderRetractCommand}"
                                            Content="缩回" />
                                </UniformGrid>
                            </StackPanel>

                            <!-- 夹爪控制按钮 -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="Gripper">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="夹爪控制"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Opacity="0.7"
                                           Margin="0,0,0,10"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                <UniformGrid Columns="2" Rows="1">
                                    <Button Height="52"
                                            Margin="0,0,6,0"
                                            Command="{Binding GripperCloseCommand}"
                                            Content="夹紧"
                                            Style="{StaticResource ButtonPrimary}" />
                                    <Button Height="52"
                                            Command="{Binding GripperOpenCommand}"
                                            Content="打开" />
                                </UniformGrid>
                            </StackPanel>

                            <!-- 真空控制按钮 -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="Vacuum">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="真空控制"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Opacity="0.7"
                                           Margin="0,0,0,10"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                <UniformGrid Columns="2" Rows="1">
                                    <Button Height="52"
                                            Margin="0,0,6,0"
                                            Command="{Binding VacuumOnCommand}"
                                            Content="吸真空"
                                            Style="{StaticResource ButtonPrimary}" />
                                    <Button Height="52"
                                            Command="{Binding VacuumOffCommand}"
                                            Content="破真空" />
                                </UniformGrid>
                            </StackPanel>

                            <!-- 灯塔控制按钮 -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.ActuatorType}" Value="StackLight">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="灯塔状态控制"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Opacity="0.7"
                                           Margin="0,0,0,10"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                <UniformGrid Columns="2" Margin="0,0,0,6">
                                    <Button Height="44"
                                            Margin="0,0,6,6"
                                            Command="{Binding StackLightIdleCommand}"
                                            Content="空闲（绿）"
                                            Style="{StaticResource ButtonSuccess}" />
                                    <Button Height="44"
                                            Margin="0,0,0,6"
                                            Command="{Binding StackLightRunningCommand}"
                                            Content="运行（绿）"
                                            Style="{StaticResource ButtonSuccess}" />
                                    <Button Height="44"
                                            Margin="0,0,6,6"
                                            Command="{Binding StackLightWarningCommand}"
                                            Content="警告（黄）"
                                            Style="{StaticResource ButtonWarning}" />
                                    <Button Height="44"
                                            Margin="0,0,0,6"
                                            Command="{Binding StackLightAlarmCommand}"
                                            Content="报警（红）"
                                            Style="{StaticResource ButtonDanger}" />
                                </UniformGrid>
                                <Button Height="44"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding StackLightOffCommand}"
                                        Content="熄灭" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 右侧：执行器详情 -->
            <Border Grid.Column="4"
                    CornerRadius="8"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">

                <!-- 未选中提示 -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock HorizontalAlignment="Center" FontSize="24" Opacity="0.15" Text="ℹ" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12"
                               Opacity="0.4"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="选择执行器查看详情" />
                </StackPanel>

                <!-- 详情内容 -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="14,10"
                            CornerRadius="8,8,0,0"
                            Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding SelectedItem.DisplayName, FallbackValue=—}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="10"
                                       Opacity="0.6"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding SelectedItem.Name, FallbackValue=—}" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="14,12,14,12">
                            <hc:Shield Margin="0,0,0,6"
                                       HorizontalAlignment="Left"
                                       Subject="类型"
                                       Status="{Binding SelectedItem.TypeDisplay}"
                                       Color="#455A64" />
                            <hc:Shield Margin="0,0,0,6"
                                       HorizontalAlignment="Left"
                                       Subject="状态A"
                                       Status="{Binding SelectedItem.StateALabel}"
                                       Color="#1565C0" />
                            <hc:Shield Margin="0,0,0,6"
                                       HorizontalAlignment="Left"
                                       Subject="状态B"
                                       Status="{Binding SelectedItem.StateBLabel}"
                                       Color="#388E3C" />

                            <Rectangle Height="1"
                                       Margin="0,10,0,10"
                                       Fill="{DynamicResource BorderBrush}"
                                       Opacity="0.5" />

                            <TextBlock FontSize="12"
                                       Opacity="0.55"
                                       Margin="0,0,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="说明" />
                            <TextBlock FontSize="12"
                                       Opacity="0.82"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding SelectedItem.Description, TargetNullValue=—}" />

                            <TextBlock FontSize="12"
                                       Opacity="0.55"
                                       Margin="0,0,0,4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="备注" />
                            <TextBlock FontSize="12"
                                       Opacity="0.72"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding SelectedItem.Remark, TargetNullValue=—}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="{Binding StatusText}" />
        </Border>
    </Grid>
</UserControl>
