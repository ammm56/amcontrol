<UserControl x:Class="AMControlWPF.Views.Motion.MotionAxisView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AMControlWPF.Views.Motion"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Padding="12,10"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left">
                    <TextBlock VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="当前轴：" />
                    <TextBlock VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryBrush}"
                       Text="Axis-01 传动X轴" />
                </StackPanel>

                <WrapPanel HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   DockPanel.Dock="Right">
                    <Button MinWidth="72" Margin="0,0,8,0" Content="刷新" />
                    <Button MinWidth="72" Margin="0,0,8,0" Content="使能" />
                    <Button MinWidth="72" Margin="0,0,8,0" Content="停止" />
                    <Button MinWidth="72" Margin="0,0,0,0" Content="回零" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- 主体区 -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧轴列表 -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="轴列表" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding AxisItems}"
                             SelectedItem="{Binding SelectedAxisItem, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource ViewNavItemStyle}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                               Text="{Binding DisplayTitle}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="12"
                                               Opacity="0.75"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                               Text="{Binding StateText}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧单页工作台 -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0">
                        <Border Width="180"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="规划位置(mm)" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAxisItem.CommandPositionMm, StringFormat=F3}" />
                            </StackPanel>
                        </Border>

                        <Border Width="180"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="编码器位置(mm)" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAxisItem.EncoderPositionMm, StringFormat=F3}" />
                            </StackPanel>
                        </Border>

                        <Border Width="180"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="默认速度(mm/s)" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           Text="{Binding SelectedAxisItem.DefaultVelocityMm, StringFormat=F3}" />
                            </StackPanel>
                        </Border>

                        <Border Width="180"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="当前状态" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Text="{Binding SelectedAxisItem.StateText}" />
                            </StackPanel>
                        </Border>

                        <Border Width="180"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="位置误差(mm)" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAxisItem.CommandPositionMm, StringFormat=F3}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- 主操作区 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="{DynamicResource SecondaryRegionBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="手动操作" />

                                    <WrapPanel Grid.Row="2">
                                        <Button MinWidth="100" Margin="0,0,8,8" Command="{Binding JogNegativeCommand}" Content="Jog -" />
                                        <Button MinWidth="100" Margin="0,0,8,8" Command="{Binding JogPositiveCommand}" Content="Jog +" />
                                        <Button MinWidth="100" Margin="0,0,8,8" Command="{Binding StopCommand}" Content="平停" />
                                        <Button MinWidth="100" Margin="0,0,8,8" Command="{Binding EmergencyStopCommand}" Content="急停" />
                                    </WrapPanel>

                                    <WrapPanel Grid.Row="4">
                                        <Button MinWidth="100" Margin="0,0,8,8" Command="{Binding ServoOnCommand}" Content="使能" />
                                        <Button MinWidth="100" Margin="0,0,8,8" Command="{Binding ServoOffCommand}" Content="失能" />
                                        <Button MinWidth="100" Margin="0,0,8,8" Command="{Binding HomeCommand}" Content="回零" />
                                    </WrapPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="{DynamicResource SecondaryRegionBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="绝对定位" />

                                        <TextBlock Grid.Row="2"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="目标位置(mm)" />
                                        <TextBox Grid.Row="4"
                                                 Height="30"
                                                 Text="{Binding TargetPositionMmText, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Row="6"
                                                Height="32"
                                                Command="{Binding MoveAbsoluteCommand}"
                                                Content="执行绝对定位" />
                                    </Grid>

                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="相对移动 / 速度" />

                                        <TextBlock Grid.Row="2"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="相对距离(mm)" />
                                        <TextBox Grid.Row="4"
                                                 Height="30"
                                                 Text="{Binding MoveDistanceMmText, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="6"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="速度(mm/s)" />
                                        <TextBox Grid.Row="8"
                                                 Height="30"
                                                 Text="{Binding VelocityMmText, UpdateSourceTrigger=PropertyChanged}" />

                                        <WrapPanel Grid.Row="10" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 底部日志 -->
                        <Border Grid.Column="2"
                                Padding="12"
                                CornerRadius="8"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="轴动作记录" />

                                <DataGrid Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          RowHeaderWidth="0"
                                          GridLinesVisibility="None"
                                          HorizontalGridLinesBrush="Transparent"
                                          VerticalGridLinesBrush="Transparent"
                                          SelectionUnit="FullRow"
                                          Margin="0">       
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="时间" Width="180" Binding="{Binding}" />
                                        <DataGridTextColumn Header="级别" Width="90" Binding="{Binding}" />
                                        <DataGridTextColumn Header="内容" Width="*" Binding="{Binding}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- 页内状态栏 -->
        <Border Grid.Row="2"
                Padding="12,0"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="最后刷新：2026-03-17 22:30:00" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="当前轴：Axis-01 传动X轴" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>