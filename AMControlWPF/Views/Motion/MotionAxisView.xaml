<UserControl x:Class="AMControlWPF.Views.Motion.MotionAxisView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="MotionActionTileButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="78" />
            <Setter Property="Height" Value="66" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#607D8B" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TileRoot"
                                Padding="10,9"
                                CornerRadius="6"
                                BorderThickness="1"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                BorderBrush="Transparent"
                                Effect="{StaticResource EffectShadow2}">
                            <Grid>
                                <Border HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Padding="5,2"
                                        CornerRadius="3"
                                        Background="{TemplateBinding Background}">
                                    <TextBlock FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="{TemplateBinding Tag}" />
                                </Border>

                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Padding="0,12,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{TemplateBinding Content}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileRoot"
                                        Property="BorderBrush"
                                        Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TileRoot"
                                        Property="Opacity"
                                        Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TileRoot"
                                        Property="Opacity"
                                        Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MotionInputTileBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="140" />
            <Setter Property="Height" Value="86" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Effect" Value="{StaticResource EffectShadow2}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="RootToolbarRow" Height="Auto" />
            <RowDefinition x:Name="RootContentRow" Height="*" />
            <RowDefinition x:Name="RootStatusRow" Height="40" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Padding="12,8"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="单轴控制" />

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button MinWidth="72"
                            Command="{Binding RefreshCommand}"
                            Content="刷新" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="控制卡" />
                    <ComboBox Width="220"
                              Height="28"
                              VerticalContentAlignment="Center"
                              ItemsSource="{Binding CardFilters}"
                              SelectedItem="{Binding SelectedCardFilter, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主体区 -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="235" />
            </Grid.ColumnDefinitions>

            <!-- 左侧轴列表 -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="AxisListHeaderRow" Height="Auto" />
                        <RowDefinition x:Name="AxisListGapRow" Height="8" />
                        <RowDefinition x:Name="AxisListContentRow" Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="轴列表" />
                        <TextBlock DockPanel.Dock="Right"
                                   FontSize="11"
                                   Opacity="0.55"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="{Binding AxisItems.Count, StringFormat='共 {0} 轴'}" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ListBox ItemsSource="{Binding AxisItems}"
                                 SelectedItem="{Binding SelectedAxisItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Effect="{StaticResource EffectShadow2}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel Margin="10,8,10,8">
                                            <DockPanel LastChildFill="False">
                                                <Border DockPanel.Dock="Left"
                                                        Padding="5,2"
                                                        CornerRadius="3"
                                                        Background="{DynamicResource PrimaryBrush}">
                                                    <TextBlock FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="{Binding LogicalAxis, StringFormat='L#{0}'}" />
                                                </Border>
                                            </DockPanel>

                                            <TextBlock Margin="0,6,0,0"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding DisplayTitle}" />

                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="11"
                                                       Opacity="0.6"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding Name}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 中间控制区 -->
            <Border Grid.Column="2"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="12,9"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="8,8,0,0">
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="控制动作" />
                    </Border>

                    <Grid Grid.Row="1">
                        <!-- 未选轴提示 -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAxisItem}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock HorizontalAlignment="Center" FontSize="28" Opacity="0.15" Text="⇌" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="14"
                                       Opacity="0.4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="请先在左侧选择一个轴" />
                        </StackPanel>

                        <!-- 已选轴磁贴区 -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAxisItem}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="4,6,4,4">
                                <WrapPanel Orientation="Horizontal">

                                    <Button Style="{StaticResource MotionActionTileButtonStyle}"
                                            Background="#1976D2"
                                            Tag="基础操作"
                                            Content="使能"
                                            Command="{Binding ServoOnCommand}" />

                                    <Button Style="{StaticResource MotionActionTileButtonStyle}"
                                            Background="#1976D2"
                                            Tag="基础操作"
                                            Content="失能"
                                            Command="{Binding ServoOffCommand}" />

                                    <Button Style="{StaticResource MotionActionTileButtonStyle}"
                                            Background="#F57C00"
                                            Tag="回零"
                                            Content="回零"
                                            Command="{Binding HomeCommand}" />

                                    <Button Style="{StaticResource MotionActionTileButtonStyle}"
                                            Background="#607D8B"
                                            Tag="维护"
                                            Content="清状态"
                                            Command="{Binding ClearStatusCommand}" />

                                    <Button Style="{StaticResource MotionActionTileButtonStyle}"
                                            Background="#00897B"
                                            Tag="停止"
                                            Content="平停"
                                            Command="{Binding StopCommand}" />

                                    <Button Style="{StaticResource MotionActionTileButtonStyle}"
                                            Background="#D32F2F"
                                            Tag="停止"
                                            Content="急停"
                                            Command="{Binding EmergencyStopCommand}" />

                                    <Button Style="{StaticResource MotionActionTileButtonStyle}"
                                            Background="#5E35B1"
                                            Tag="Jog"
                                            Content="负运动"
                                            Command="{Binding JogNegativeCommand}" />

                                    <Button Style="{StaticResource MotionActionTileButtonStyle}"
                                            Background="#5E35B1"
                                            Tag="Jog"
                                            Content="停止"
                                            Command="{Binding JogStopCommand}" />

                                    <Button Style="{StaticResource MotionActionTileButtonStyle}"
                                            Background="#5E35B1"
                                            Tag="Jog"
                                            Content="正运动"
                                            Command="{Binding JogPositiveCommand}" />

                                    <Border Style="{StaticResource MotionInputTileBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <DockPanel Grid.Row="0" LastChildFill="False">
                                                <Border DockPanel.Dock="Left"
                                                        Padding="5,2"
                                                        CornerRadius="3"
                                                        Background="#607D8B">
                                                    <TextBlock FontSize="9"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="输入" />
                                                </Border>
                                                <Button DockPanel.Dock="Right"
                                                        Width="72"
                                                        Height="24"
                                                        Margin="8,0,0,0"
                                                        Command="{Binding ApplyVelocityCommand}"
                                                        Content="应用速度" />
                                            </DockPanel>

                                            <TextBox Grid.Row="1"
                                                     Margin="0,10,0,0"
                                                     VerticalContentAlignment="Center"
                                                     HorizontalContentAlignment="Center"
                                                     FontSize="18"
                                                     Text="{Binding VelocityMmText, UpdateSourceTrigger=PropertyChanged}"
                                                     hc:TitleElement.Title="速度(mm/s)"
                                                     hc:TitleElement.TitlePlacement="Top" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource MotionInputTileBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <DockPanel Grid.Row="0" LastChildFill="False">
                                                <Border DockPanel.Dock="Left"
                                                        Padding="5,2"
                                                        CornerRadius="3"
                                                        Background="#1976D2">
                                                    <TextBlock FontSize="9"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="定位" />
                                                </Border>
                                                <Button DockPanel.Dock="Right"
                                                        Width="72"
                                                        Height="24"
                                                        Margin="8,0,0,0"
                                                        Command="{Binding MoveAbsoluteCommand}"
                                                        Content="绝对定位" />
                                            </DockPanel>

                                            <TextBox Grid.Row="1"
                                                     Margin="0,10,0,0"
                                                     VerticalContentAlignment="Center"
                                                     HorizontalContentAlignment="Center"
                                                     FontSize="18"
                                                     Text="{Binding TargetPositionMmText, UpdateSourceTrigger=PropertyChanged}"
                                                     hc:TitleElement.Title="绝对位置(mm)"
                                                     hc:TitleElement.TitlePlacement="Top" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource MotionInputTileBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <DockPanel Grid.Row="0" LastChildFill="False">
                                                <Border DockPanel.Dock="Left"
                                                        Padding="5,2"
                                                        CornerRadius="3"
                                                        Background="#1976D2">
                                                    <TextBlock FontSize="9"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="定位" />
                                                </Border>
                                                <Button DockPanel.Dock="Right"
                                                        Width="72"
                                                        Height="24"
                                                        Margin="8,0,0,0"
                                                        Command="{Binding MoveRelativeCommand}"
                                                        Content="相对移动" />
                                            </DockPanel>

                                            <TextBox Grid.Row="1"
                                                     Margin="0,10,0,0"
                                                     VerticalContentAlignment="Center"
                                                     HorizontalContentAlignment="Center"
                                                     FontSize="18"
                                                     Text="{Binding MoveDistanceMmText, UpdateSourceTrigger=PropertyChanged}"
                                                     hc:TitleElement.Title="相对距离(mm)"
                                                     hc:TitleElement.TitlePlacement="Top" />
                                        </Grid>
                                    </Border>

                                </WrapPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- 右侧详情 -->
            <Border Grid.Column="4"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAxisItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock HorizontalAlignment="Center" FontSize="28" Opacity="0.15" Text="⇌" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Opacity="0.4"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="请选择一个轴查看详情" />
                    </StackPanel>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAxisItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="AxisDetailHeaderRow" Height="Auto" />
                            <RowDefinition x:Name="AxisDetailContentRow" Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="14,10"
                                CornerRadius="8,8,0,0"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAxisHeader}" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="14,12,14,12">
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="控制卡"
                                           Status="{Binding SelectedAxisCardText}"
                                           Color="#455A64" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="采样状态"
                                           Status="{Binding AxisRuntimeScanStateText}"
                                           Color="#546E7A" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="更新时间"
                                           Status="{Binding SelectedAxisRuntimeUpdateTimeText}"
                                           Color="#A6E22E" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="当前状态"
                                           Status="{Binding SelectedAxisStatusText}"
                                           Color="#388E3C" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="限位状态"
                                           Status="{Binding SelectedAxisLimitText}"
                                           Color="#F57C00" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="使能状态"
                                           Status="{Binding SelectedAxisEnabledText}"
                                           Color="#1976D2" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="原点状态"
                                           Status="{Binding SelectedAxisHomeText}"
                                           Color="#5E35B1" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="到位状态"
                                           Status="{Binding SelectedAxisDoneText}"
                                           Color="#00897B" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="规划位置(mm)"
                                           Status="{Binding SelectedAxisCommandPositionText}"
                                           Color="#00838F" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="编码器位置(mm)"
                                           Status="{Binding SelectedAxisEncoderPositionText}"
                                           Color="#0097A7" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="位置误差(mm)"
                                           Status="{Binding SelectedAxisPositionErrorText}"
                                           Color="#D32F2F" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="默认速度(mm/s)"
                                           Status="{Binding SelectedAxisDefaultVelocityText}"
                                           Color="#7B1FA2" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="Jog速度(mm/s)"
                                           Status="{Binding SelectedAxisJogVelocityText}"
                                           Color="#00897B" />

                                <Rectangle Height="1"
                                           Margin="0,12,0,12"
                                           Fill="{DynamicResource BorderBrush}"
                                           Opacity="0.5" />

                                <TextBlock FontSize="12"
                                           Opacity="0.55"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="说明" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Opacity="0.75"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="当前页面用于单轴手动控制与运行状态确认。" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="{Binding StatusText}" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="{Binding SelectedAxisHeader}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>