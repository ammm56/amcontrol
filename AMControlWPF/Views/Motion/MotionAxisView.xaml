<UserControl x:Class="AMControlWPF.Views.Motion.MotionAxisView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="RootToolbarRow" Height="Auto" />
            <RowDefinition x:Name="RootContentRow" Height="*" />
            <RowDefinition x:Name="RootStatusRow" Height="40" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Padding="12,8"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="单轴控制" />

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button MinWidth="72"
                            Command="{Binding RefreshCommand}"
                            Content="刷新" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="控制卡" />
                    <ComboBox Width="220"
                              Height="28"
                              VerticalContentAlignment="Center"
                              ItemsSource="{Binding CardFilters}"
                              SelectedItem="{Binding SelectedCardFilter, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主体区 -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="250" />
            </Grid.ColumnDefinitions>

            <!-- 左侧轴列表 -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="AxisListHeaderRow" Height="Auto" />
                        <RowDefinition x:Name="AxisListGapRow" Height="8" />
                        <RowDefinition x:Name="AxisListContentRow" Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="轴列表" />
                        <TextBlock DockPanel.Dock="Right"
                                   FontSize="11"
                                   Opacity="0.55"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="{Binding AxisItems.Count, StringFormat='共 {0} 轴'}" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ListBox ItemsSource="{Binding AxisItems}"
                                 SelectedItem="{Binding SelectedAxisItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Effect="{StaticResource EffectShadow2}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel Margin="10,8,10,8">
                                            <DockPanel LastChildFill="False">
                                                <Border DockPanel.Dock="Left"
                                                        Padding="5,2"
                                                        CornerRadius="3"
                                                        Background="{DynamicResource PrimaryBrush}">
                                                    <TextBlock FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="{Binding LogicalAxis, StringFormat='L#{0}'}" />
                                                </Border>
                                                <TextBlock DockPanel.Dock="Right"
                                                           FontSize="10"
                                                           Opacity="0.5"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Text="{Binding StateText}" />
                                            </DockPanel>

                                            <TextBlock Margin="0,6,0,0"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding DisplayTitle}" />

                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="11"
                                                       Opacity="0.6"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding Name}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 中间控制工作区 -->
            <Border Grid.Column="2"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="AxisActionHeaderRow" Height="Auto" />
                        <RowDefinition x:Name="AxisActionContentRow" Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="12,9"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="8,8,0,0">
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="控制动作" />
                    </Border>

                    <Grid Grid.Row="1">
                        <!-- 未选轴提示 -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAxisItem}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock HorizontalAlignment="Center" FontSize="28" Opacity="0.15" Text="⇌" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="14"
                                       Opacity="0.4"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="请先在左侧选择一个轴" />
                        </StackPanel>

                        <!-- 已选轴控制区 -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAxisItem}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>

                            <WrapPanel Orientation="Horizontal"
                                       ItemWidth="360"
                                       Margin="8">
                                <!-- 手动控制 -->
                                <Border Width="360"
                                        Margin="0,0,8,8"
                                        Padding="12"
                                        CornerRadius="8"
                                        Background="{DynamicResource SecondaryRegionBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition x:Name="ManualTitleRow" Height="Auto" />
                                            <RowDefinition x:Name="ManualGap1Row" Height="12" />
                                            <RowDefinition x:Name="ManualServoRow" Height="Auto" />
                                            <RowDefinition x:Name="ManualGap2Row" Height="12" />
                                            <RowDefinition x:Name="ManualJogRow" Height="Auto" />
                                            <RowDefinition x:Name="ManualGap3Row" Height="12" />
                                            <RowDefinition x:Name="ManualSpeedTitleRow" Height="Auto" />
                                            <RowDefinition x:Name="ManualGap4Row" Height="8" />
                                            <RowDefinition x:Name="ManualSpeedRow" Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="手动控制" />

                                        <WrapPanel Grid.Row="2">
                                            <Button MinWidth="92"
                                                    Margin="0,0,8,8"
                                                    Command="{Binding ServoOnCommand}"
                                                    Content="使能" />
                                            <Button MinWidth="92"
                                                    Margin="0,0,8,8"
                                                    Command="{Binding ServoOffCommand}"
                                                    Content="失能" />
                                            <Button MinWidth="92"
                                                    Margin="0,0,8,8"
                                                    Command="{Binding HomeCommand}"
                                                    Content="回零" />
                                            <Button MinWidth="92"
                                                    Margin="0,0,8,8"
                                                    Command="{Binding ClearStatusCommand}"
                                                    Content="清状态" />
                                            <Button MinWidth="92"
                                                    Margin="0,0,8,8"
                                                    Command="{Binding StopCommand}"
                                                    Content="平停" />
                                            <Button MinWidth="92"
                                                    Margin="0,0,8,8"
                                                    Command="{Binding EmergencyStopCommand}"
                                                    Content="急停" />
                                        </WrapPanel>

                                        <Grid Grid.Row="4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="Jog / 手动运动" />

                                            <WrapPanel Grid.Row="2">
                                                <Button MinWidth="100"
                                                        Margin="0,0,8,8"
                                                        Command="{Binding JogNegativeCommand}"
                                                        Content="负向运动" />
                                                <Button MinWidth="100"
                                                        Margin="0,0,8,8"
                                                        Command="{Binding JogStopCommand}"
                                                        Content="Jog停止" />
                                                <Button MinWidth="100"
                                                        Margin="0,0,8,8"
                                                        Command="{Binding JogPositiveCommand}"
                                                        Content="正向运动" />
                                            </WrapPanel>
                                        </Grid>

                                        <TextBlock Grid.Row="6"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="速度(mm/s)" />

                                        <Grid Grid.Row="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="110" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox Grid.Column="0"
                                                     Height="30"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding VelocityMmText, UpdateSourceTrigger=PropertyChanged}" />

                                            <Button Grid.Column="2"
                                                    Height="30"
                                                    Command="{Binding ApplyVelocityCommand}"
                                                    Content="应用速度" />
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- 定位控制 -->
                                <Border Width="360"
                                        Margin="0,0,8,8"
                                        Padding="12"
                                        CornerRadius="8"
                                        Background="{DynamicResource SecondaryRegionBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition x:Name="PosTitleRow" Height="Auto" />
                                            <RowDefinition x:Name="PosGap1Row" Height="12" />
                                            <RowDefinition x:Name="AbsTitleRow" Height="Auto" />
                                            <RowDefinition x:Name="AbsGap1Row" Height="8" />
                                            <RowDefinition x:Name="AbsInputRow" Height="Auto" />
                                            <RowDefinition x:Name="AbsGap2Row" Height="8" />
                                            <RowDefinition x:Name="AbsBtnRow" Height="Auto" />
                                            <RowDefinition x:Name="PosGap2Row" Height="14" />
                                            <RowDefinition x:Name="RelTitleRow" Height="Auto" />
                                            <RowDefinition x:Name="RelGap1Row" Height="8" />
                                            <RowDefinition x:Name="RelInputRow" Height="Auto" />
                                            <RowDefinition x:Name="RelGap2Row" Height="8" />
                                            <RowDefinition x:Name="RelBtnRow" Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="定位控制" />

                                        <TextBlock Grid.Row="2"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="绝对定位目标(mm)" />

                                        <TextBox Grid.Row="4"
                                                 Height="30"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding TargetPositionMmText, UpdateSourceTrigger=PropertyChanged}" />

                                        <Button Grid.Row="6"
                                                Height="32"
                                                Command="{Binding MoveAbsoluteCommand}"
                                                Content="执行绝对定位" />

                                        <TextBlock Grid.Row="8"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="相对移动距离(mm)" />

                                        <TextBox Grid.Row="10"
                                                 Height="30"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding MoveDistanceMmText, UpdateSourceTrigger=PropertyChanged}" />

                                        <Button Grid.Row="12"
                                                Height="32"
                                                Command="{Binding MoveRelativeCommand}"
                                                Content="执行相对移动" />
                                    </Grid>
                                </Border>
                            </WrapPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- 右侧详情 -->
            <Border Grid.Column="4"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAxisItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock HorizontalAlignment="Center" FontSize="28" Opacity="0.15" Text="⇌" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Opacity="0.4"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="请选择一个轴查看详情" />
                    </StackPanel>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAxisItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="AxisDetailHeaderRow" Height="Auto" />
                            <RowDefinition x:Name="AxisDetailContentRow" Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="14,10"
                                CornerRadius="8,8,0,0"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAxisHeader}" />
                                <TextBlock Margin="0,2,0,0"
                                           FontSize="11"
                                           Opacity="0.6"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAxisCardText}" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="14,12,14,12">
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="控制卡"
                                           Status="{Binding SelectedAxisCardText}"
                                           Color="#455A64" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="采样状态"
                                           Status="{Binding AxisRuntimeScanStateText}"
                                           Color="#546E7A" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="更新时间"
                                           Status="{Binding SelectedAxisRuntimeUpdateTimeText}"
                                           Color="#6C4A9A" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="当前状态"
                                           Status="{Binding SelectedAxisStatusText}"
                                           Color="#388E3C" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="限位状态"
                                           Status="{Binding SelectedAxisLimitText}"
                                           Color="#F57C00" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="原点/到位/使能"
                                           Status="{Binding SelectedAxisSignalText}"
                                           Color="#1976D2" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="规划位置(mm)"
                                           Status="{Binding SelectedAxisCommandPositionText}"
                                           Color="#00838F" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="编码器位置(mm)"
                                           Status="{Binding SelectedAxisEncoderPositionText}"
                                           Color="#0097A7" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="位置误差(mm)"
                                           Status="{Binding SelectedAxisPositionErrorText}"
                                           Color="#D32F2F" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="默认速度(mm/s)"
                                           Status="{Binding SelectedAxisDefaultVelocityText}"
                                           Color="#7B1FA2" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="Jog速度(mm/s)"
                                           Status="{Binding SelectedAxisJogVelocityText}"
                                           Color="#00897B" />

                                <Rectangle Height="1"
                                           Margin="0,12,0,12"
                                           Fill="{DynamicResource BorderBrush}"
                                           Opacity="0.5" />

                                <TextBlock FontSize="12"
                                           Opacity="0.55"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="说明" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Opacity="0.75"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="当前页面用于单轴手动控制与运行状态确认。采样缓存仅用于界面显示，不参与运动安全判断与控制过程判定。" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="{Binding StatusText}" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="{Binding SelectedAxisHeader}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>