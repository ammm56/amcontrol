<UserControl x:Class="AMControlWPF.Views.Motion.MotionAxisView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AMControlWPF.Views.Motion"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Padding="12,10"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left">
                    <TextBlock VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="当前轴：" />
                    <TextBlock VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryBrush}"
                       Text="Axis-01 传动X轴" />
                </StackPanel>

                <WrapPanel HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   DockPanel.Dock="Right">
                    <Button MinWidth="72" Margin="0,0,8,6" Content="刷新" />
                    <Button MinWidth="72" Margin="0,0,8,6" Content="使能" />
                    <Button MinWidth="72" Margin="0,0,8,6" Content="停止" />
                    <Button MinWidth="72" Margin="0,0,0,6" Content="回零" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- 主体区 -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧轴列表 -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="轴列表" />

                    <ListBox x:Name="ListBoxAxis"
                             Grid.Row="2"
                             SelectedIndex="0">
                        <ListBoxItem Content="Axis-01 传动X轴" />
                        <ListBoxItem Content="Axis-02 传动Y轴" />
                        <ListBoxItem Content="Axis-03 压装Z轴" />
                        <ListBoxItem Content="Axis-04 搬运R轴" />
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧单页工作台 -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 顶部指标 -->
                    <WrapPanel Grid.Row="2">
                        <Border Width="160"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="规划位置(mm)" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="123.456" />
                            </StackPanel>
                        </Border>

                        <Border Width="160"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="编码器位置(mm)" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="123.441" />
                            </StackPanel>
                        </Border>

                        <Border Width="160"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="速度(mm/s)" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="25.000" />
                            </StackPanel>
                        </Border>

                        <Border Width="160"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="状态" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Text="Ready" />
                            </StackPanel>
                        </Border>

                        <Border Width="160"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="当前位置误差(mm)" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="0.015" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- 主操作区 -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="240" />
                            </Grid.ColumnDefinitions>

                            <!-- 左：控制区 -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Padding="12"
                                        CornerRadius="8"
                                        Background="{DynamicResource SecondaryRegionBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="手动操作" />

                                        <WrapPanel Grid.Row="2">
                                            <Button MinWidth="100" Margin="0,0,8,8" Content="点动 -" />
                                            <Button MinWidth="100" Margin="0,0,8,8" Content="点动 +" />
                                            <Button MinWidth="100" Margin="0,0,8,8" Content="连续 -" />
                                            <Button MinWidth="100" Margin="0,0,8,8" Content="连续 +" />
                                        </WrapPanel>

                                        <WrapPanel Grid.Row="4">
                                            <Button MinWidth="100" Margin="0,0,8,8" Content="复位" />
                                            <Button MinWidth="100" Margin="0,0,8,8" Content="回零" />
                                            <Button MinWidth="100" Margin="0,0,8,8" Content="停止" />
                                            <Button MinWidth="100" Margin="0,0,8,8" Content="急停" />
                                        </WrapPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2"
                                        Padding="12"
                                        CornerRadius="8"
                                        Background="{DynamicResource SecondaryRegionBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="220" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="定位输入" />

                                            <TextBlock Grid.Row="2"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="目标位置(mm)" />
                                            <TextBox Grid.Row="4"
                                                     Height="30"
                                                     Text="100.000" />

                                            <Button Grid.Row="6"
                                                    Height="32"
                                                    Content="执行定位" />
                                        </Grid>

                                        <Grid Grid.Column="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="速度设置" />

                                            <TextBlock Grid.Row="2"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="速度(mm/s)" />
                                            <TextBox Grid.Row="4"
                                                     Height="30"
                                                     Text="25.000" />

                                            <Button Grid.Row="6"
                                                    Height="32"
                                                    Content="应用速度" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- 右：状态与信号 -->
                            <Border Grid.Column="2"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="{DynamicResource SecondaryRegionBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="轴状态与信号" />

                                    <StackPanel Grid.Row="2">
                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                CornerRadius="6"
                                                Background="{DynamicResource RegionBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="Servo On" />
                                                <TextBlock Grid.Column="1" Foreground="{DynamicResource SuccessBrush}" Text="ON" />
                                            </Grid>
                                        </Border>

                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                CornerRadius="6"
                                                Background="{DynamicResource RegionBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="Alarm" />
                                                <TextBlock Grid.Column="1" Foreground="{DynamicResource DangerBrush}" Text="OFF" />
                                            </Grid>
                                        </Border>

                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                CornerRadius="6"
                                                Background="{DynamicResource RegionBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="正限位" />
                                                <TextBlock Grid.Column="1" Foreground="{DynamicResource PrimaryTextBrush}" Text="OFF" />
                                            </Grid>
                                        </Border>

                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                CornerRadius="6"
                                                Background="{DynamicResource RegionBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="负限位" />
                                                <TextBlock Grid.Column="1" Foreground="{DynamicResource PrimaryTextBrush}" Text="OFF" />
                                            </Grid>
                                        </Border>

                                        <Border Padding="10"
                                                CornerRadius="6"
                                                Background="{DynamicResource RegionBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="原点信号" />
                                                <TextBlock Grid.Column="1" Foreground="{DynamicResource PrimaryTextBrush}" Text="ON" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 底部日志 -->
                        <Border Grid.Row="2"
                                Padding="12"
                                CornerRadius="8"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="轴动作记录" />

                                <DataGrid Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          CanUserAddRows="False"
                                          IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="时间" Width="180" Binding="{Binding}" />
                                        <DataGridTextColumn Header="级别" Width="90" Binding="{Binding}" />
                                        <DataGridTextColumn Header="内容" Width="*" Binding="{Binding}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- 页内状态栏 -->
        <Border Grid.Row="2"
                Padding="12,0"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="最后刷新：2026-03-17 22:30:00" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="当前轴：Axis-01 传动X轴" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>