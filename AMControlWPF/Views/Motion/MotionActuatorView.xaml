<UserControl x:Class="AMControlWPF.Views.Motion.MotionActuatorView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="ActuatorStateBadgeBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#607D8B" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StateLevel}" Value="Success">
                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StateLevel}" Value="Primary">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StateLevel}" Value="Warning">
                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StateLevel}" Value="Danger">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StateLevel}" Value="Secondary">
                    <Setter Property="Background" Value="{DynamicResource SecondaryTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="RootToolbarRow" Height="Auto" />
            <RowDefinition x:Name="RootContentRow" Height="*" />
            <RowDefinition x:Name="RootStatusRow" Height="40" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Padding="12,8"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="执行器控制" />

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button MinWidth="72"
                            Command="{Binding RefreshCommand}"
                            Content="刷新" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <Button Width="46"
                            Height="28"
                            Content="全部"
                            Command="{Binding ChangeTypeFilterCommand}"
                            CommandParameter="All">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterAll}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Width="46"
                            Height="28"
                            Margin="4,0,0,0"
                            Content="气缸"
                            Command="{Binding ChangeTypeFilterCommand}"
                            CommandParameter="Cylinder">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterCylinder}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Width="46"
                            Height="28"
                            Margin="4,0,0,0"
                            Content="真空"
                            Command="{Binding ChangeTypeFilterCommand}"
                            CommandParameter="Vacuum">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterVacuum}" Value="True">
                                        <Setter Property="Background" Value="#03A9F4" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Width="46"
                            Height="28"
                            Margin="4,0,0,0"
                            Content="夹爪"
                            Command="{Binding ChangeTypeFilterCommand}"
                            CommandParameter="Gripper">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterGripper}" Value="True">
                                        <Setter Property="Background" Value="#9C27B0" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Width="46"
                            Height="28"
                            Margin="4,0,0,0"
                            Content="灯塔"
                            Command="{Binding ChangeTypeFilterCommand}"
                            CommandParameter="StackLight">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterStackLight}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBox Width="180"
                             Height="28"
                             Margin="12,0,0,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主体区 -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="250" />
            </Grid.ColumnDefinitions>

            <!-- 左侧卡片区 -->
            <Border Grid.Column="0"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="SummaryRow" Height="Auto" />
                        <RowDefinition x:Name="CardListRow" Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10,10,10,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="当前对象数" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding TotalCount}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="气缸" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           Text="{Binding CylinderCount}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="真空" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#03A9F4"
                                           Text="{Binding VacuumCount}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="夹爪" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#9C27B0"
                                           Text="{Binding GripperCount}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="灯塔" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource WarningBrush}"
                                           Text="{Binding StackLightCount}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="4,6,4,4">
                        <ListBox ItemsSource="{Binding Items}"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 VerticalContentAlignment="Stretch">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="OverridesDefaultStyle" Value="True" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="154"
                                            Margin="5"
                                            Padding="9,8"
                                            CornerRadius="6"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Effect="{StaticResource EffectShadow2}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <Border DockPanel.Dock="Left"
                                                        CornerRadius="3"
                                                        Padding="5,2"
                                                        Margin="0,0,6,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#607D8B" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ActuatorType}" Value="Cylinder">
                                                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ActuatorType}" Value="Vacuum">
                                                                    <Setter Property="Background" Value="#03A9F4" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ActuatorType}" Value="Gripper">
                                                                    <Setter Property="Background" Value="#9C27B0" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ActuatorType}" Value="StackLight">
                                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="{Binding TypeDisplay}" />
                                                </Border>

                                                <Border DockPanel.Dock="Left"
                                                        Style="{StaticResource ActuatorStateBadgeBorderStyle}"
                                                        CornerRadius="3"
                                                        Padding="5,2">
                                                    <TextBlock FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="{Binding StateText}" />
                                                </Border>
                                            </DockPanel>

                                            <TextBlock Margin="0,7,0,0"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="34"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding DisplayTitle}" />

                                            <TextBlock Margin="0,3,0,0"
                                                       FontSize="10"
                                                       Opacity="0.65"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding Name}" />

                                            <TextBlock Margin="0,3,0,0"
                                                       FontSize="10"
                                                       Opacity="0.72"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding CardLine1Text}" />

                                            <TextBlock Margin="0,3,0,0"
                                                       FontSize="10"
                                                       Opacity="0.72"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding CardLine2Text}" />

                                            <Border Margin="0,7,0,0"
                                                    Padding="6,3"
                                                    CornerRadius="4"
                                                    Background="{DynamicResource RegionBrush}">
                                                <TextBlock FontSize="10"
                                                           Opacity="0.82"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Text="{Binding FooterText}" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 右侧详情与控制区 -->
            <Grid Grid.Column="2">
                <Border CornerRadius="8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center" FontSize="28" Opacity="0.15" Text="◉" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="13"
                                   Opacity="0.4"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="请选择一个执行器对象查看详情" />
                    </StackPanel>
                </Border>

                <Border CornerRadius="8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="14,10"
                                CornerRadius="8,8,0,0"
                                Background="{DynamicResource RegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedItemHeader}" />
                                <TextBlock Margin="0,2,0,0"
                                           FontSize="11"
                                           Opacity="0.6"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedItemSubHeader}" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="14,12,14,12">

                                <!-- 气缸操作 -->
                                <Border Margin="0,0,0,12"
                                        Padding="10"
                                        CornerRadius="6"
                                        Background="{DynamicResource RegionBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCylinderSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel>
                                        <CheckBox Content="等待反馈"
                                                  IsChecked="{Binding WaitFeedback, Mode=TwoWay}" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button MinWidth="74"
                                                    Height="32"
                                                    Margin="0,0,8,0"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Foreground="White"
                                                    Command="{Binding ExecutePrimaryActionCommand}"
                                                    Content="伸出" />
                                            <Button MinWidth="74"
                                                    Height="32"
                                                    Background="{DynamicResource InfoBrush}"
                                                    Foreground="White"
                                                    Command="{Binding ExecuteSecondaryActionCommand}"
                                                    Content="缩回" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 真空操作 -->
                                <Border Margin="0,0,0,12"
                                        Padding="10"
                                        CornerRadius="6"
                                        Background="{DynamicResource RegionBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVacuumSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel>
                                        <CheckBox Content="等待反馈"
                                                  IsChecked="{Binding WaitFeedback, Mode=TwoWay}" />
                                        <CheckBox Margin="0,4,0,0"
                                                  Content="等待工件检测"
                                                  IsChecked="{Binding WaitWorkpiece, Mode=TwoWay}" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button MinWidth="74"
                                                    Height="32"
                                                    Margin="0,0,8,0"
                                                    Background="#03A9F4"
                                                    Foreground="White"
                                                    Command="{Binding ExecutePrimaryActionCommand}"
                                                    Content="吸真空" />
                                            <Button MinWidth="74"
                                                    Height="32"
                                                    Background="{DynamicResource WarningBrush}"
                                                    Foreground="White"
                                                    Command="{Binding ExecuteSecondaryActionCommand}"
                                                    Content="关闭真空" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 夹爪操作 -->
                                <Border Margin="0,0,0,12"
                                        Padding="10"
                                        CornerRadius="6"
                                        Background="{DynamicResource RegionBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGripperSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel>
                                        <CheckBox Content="等待反馈"
                                                  IsChecked="{Binding WaitFeedback, Mode=TwoWay}" />
                                        <CheckBox Margin="0,4,0,0"
                                                  Content="等待工件检测"
                                                  IsChecked="{Binding WaitWorkpiece, Mode=TwoWay}" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button MinWidth="74"
                                                    Height="32"
                                                    Margin="0,0,8,0"
                                                    Background="#9C27B0"
                                                    Foreground="White"
                                                    Command="{Binding ExecutePrimaryActionCommand}"
                                                    Content="夹紧" />
                                            <Button MinWidth="74"
                                                    Height="32"
                                                    Background="{DynamicResource SuccessBrush}"
                                                    Foreground="White"
                                                    Command="{Binding ExecuteSecondaryActionCommand}"
                                                    Content="打开" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 灯塔操作 -->
                                <Border Margin="0,0,0,12"
                                        Padding="10"
                                        CornerRadius="6"
                                        Background="{DynamicResource RegionBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStackLightSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel>
                                        <CheckBox Content="蜂鸣器联动"
                                                  IsChecked="{Binding StackLightWithBuzzer, Mode=TwoWay}" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button MinWidth="60"
                                                    Height="32"
                                                    Margin="0,0,8,8"
                                                    Command="{Binding SetStackLightStateCommand}"
                                                    CommandParameter="Off"
                                                    Content="熄灭" />

                                            <Button MinWidth="60"
                                                    Height="32"
                                                    Margin="0,0,8,8"
                                                    Background="{DynamicResource SuccessBrush}"
                                                    Foreground="White"
                                                    Command="{Binding SetStackLightStateCommand}"
                                                    CommandParameter="Idle"
                                                    Content="空闲" />

                                            <Button MinWidth="60"
                                                    Height="32"
                                                    Margin="0,0,8,8"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Foreground="White"
                                                    Command="{Binding SetStackLightStateCommand}"
                                                    CommandParameter="Running"
                                                    Content="运行" />

                                            <Button MinWidth="60"
                                                    Height="32"
                                                    Margin="0,0,8,8"
                                                    Background="{DynamicResource WarningBrush}"
                                                    Foreground="White"
                                                    Command="{Binding SetStackLightStateCommand}"
                                                    CommandParameter="Warning"
                                                    Content="警告" />

                                            <Button MinWidth="60"
                                                    Height="32"
                                                    Margin="0,0,0,8"
                                                    Background="{DynamicResource DangerBrush}"
                                                    Foreground="White"
                                                    Command="{Binding SetStackLightStateCommand}"
                                                    CommandParameter="Alarm"
                                                    Content="报警" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="当前状态"
                                           Status="{Binding SelectedItem.StateText}"
                                           Color="#1976D2" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="状态细节"
                                           Status="{Binding SelectedItem.DetailText}"
                                           Color="#00796B" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="控制模式"
                                           Status="{Binding SelectedItem.ControlModeText}"
                                           Color="#455A64" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="输出 1"
                                           Status="{Binding SelectedItem.PrimaryOutputText}"
                                           Color="#1565C0" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="输出 2"
                                           Status="{Binding SelectedItem.SecondaryOutputText}"
                                           Color="#5D4037" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="反馈 1"
                                           Status="{Binding SelectedItem.PrimaryFeedbackText}"
                                           Color="#2E7D32" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="反馈 2"
                                           Status="{Binding SelectedItem.SecondaryFeedbackText}"
                                           Color="#00838F" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="工件检测"
                                           Status="{Binding SelectedItem.WorkpieceText}"
                                           Color="#8E24AA" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="超时/联动"
                                           Status="{Binding SelectedItem.TimeoutText}"
                                           Color="#F57C00" />
                                <hc:Shield Margin="0,0,0,6"
                                           HorizontalAlignment="Left"
                                           Subject="最后刷新"
                                           Status="{Binding SelectedItem.RuntimeUpdateTimeText}"
                                           Color="#A6E22E" />

                                <Rectangle Height="1"
                                           Margin="0,12,0,12"
                                           Fill="{DynamicResource BorderBrush}"
                                           Opacity="0.5" />

                                <TextBlock FontSize="12"
                                           Opacity="0.55"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="说明" />
                                <TextBlock FontSize="12"
                                           Opacity="0.82"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedItem.Description, TargetNullValue=—}" />

                                <TextBlock FontSize="12"
                                           Opacity="0.55"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="备注" />
                                <TextBlock FontSize="12"
                                           Opacity="0.72"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedItem.Remark, TargetNullValue=—}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,0">
            <Grid>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="{Binding StatusText}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>