<UserControl x:Class="AMControlWPF.Views.Alarm.AlarmHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Row 0: 筛选条 ── -->
        <Border Grid.Row="0"
                Padding="12,10"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="报警历史" />
                <WrapPanel HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right">
                    <DatePicker Width="130" Height="30" Margin="0,0,8,6"
                                SelectedDate="{Binding StartDate, Mode=TwoWay}" />
                    <DatePicker Width="130" Height="30" Margin="0,0,8,6"
                                SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                    <Button MinWidth="72" Margin="0,0,8,6"
                            Command="{Binding QueryCommand}" Content="查询" />
                    <Button MinWidth="72" Margin="0,0,8,6"
                            Command="{Binding RefreshCommand}" Content="刷新" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- ── Row 1: 主内容区 ── -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="8"   />
                <ColumnDefinition Width="*"   />
            </Grid.ColumnDefinitions>

            <!-- 左侧筛选栏 -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8"    />
                        <RowDefinition Height="*"    />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="报警筛选" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Filters}"
                             SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource ViewNavItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧内容区 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8"    />
                    <RowDefinition Height="*"    />
                </Grid.RowDefinitions>

                <!-- 统计卡片 -->
                <WrapPanel Grid.Row="0">
                    <Border Width="160" Margin="0,0,8,8" Padding="10" CornerRadius="6"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7" Foreground="{DynamicResource PrimaryTextBrush}" Text="报警总数" />
                            <TextBlock FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding TotalAllCount}" />
                        </StackPanel>
                    </Border>
                    <Border Width="160" Margin="0,0,8,8" Padding="10" CornerRadius="6"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7" Foreground="{DynamicResource PrimaryTextBrush}" Text="未清除" />
                            <TextBlock FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WarningBrush}"
                                       Text="{Binding UnclearedCount}" />
                        </StackPanel>
                    </Border>
                    <Border Width="160" Margin="0,0,8,8" Padding="10" CornerRadius="6"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7" Foreground="{DynamicResource PrimaryTextBrush}" Text="当前筛选" />
                            <TextBlock FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       Text="{Binding FilteredCount}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- DataGrid + 详情面板 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"   />
                        <ColumnDefinition Width="8"   />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <!-- DataGrid -->
                    <Border Grid.Column="0"
                            Padding="12"
                            CornerRadius="8"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8"    />
                                <RowDefinition Height="*"    />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="报警记录列表" />

                            <DataGrid Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="None"
                                      ItemsSource="{Binding Alarms}"
                                      SelectedItem="{Binding SelectedAlarm, Mode=TwoWay}">
                                <DataGrid.Columns>

                                    <DataGridTextColumn Header="触发时间" Width="160"
                                                        Binding="{Binding RaisedTime, StringFormat=yyyy-MM-dd HH:mm:ss}" />

                                    <DataGridTextColumn Header="级别" Width="72"
                                                        Binding="{Binding AlarmLevel}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                                <Setter Property="FontWeight"  Value="SemiBold" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AlarmLevel}" Value="Critical">
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AlarmLevel}" Value="Error">
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AlarmLevel}" Value="Warning">
                                                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AlarmLevel}" Value="Info">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="报警码" Width="72"
                                                        Binding="{Binding AlarmCode}" />

                                    <DataGridTextColumn Header="来源" Width="120"
                                                        Binding="{Binding Source}" />

                                    <DataGridTemplateColumn Header="状态" Width="72">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text"       Value="未清除" />
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCleared}" Value="True">
                                                                    <Setter Property="Text"    Value="已清除" />
                                                                    <Setter Property="Opacity" Value="0.55" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="消息" Width="*"
                                                        Binding="{Binding Message}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- 详情面板 -->
                    <Border Grid.Column="2"
                            Padding="12"
                            CornerRadius="8"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12"   />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8"    />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8"    />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8"    />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8"    />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8"    />
                                <RowDefinition Height="*"    />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="报警详情" />

                            <Border Grid.Row="2" Padding="10" CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAlarm.RaisedTime,
                                               TargetNullValue=触发时间：-,
                                               StringFormat=触发时间：{0:yyyy-MM-dd HH:mm:ss}}" />
                            </Border>

                            <Border Grid.Row="4" Padding="10" CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAlarm.AlarmLevel,
                                               TargetNullValue=级别：-,
                                               StringFormat=级别：{0}}" />
                            </Border>

                            <Border Grid.Row="6" Padding="10" CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAlarm.AlarmCode,
                                               StringFormat=报警码：{0}}" />
                            </Border>

                            <Border Grid.Row="8" Padding="10" CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAlarm.Source,
                                               TargetNullValue=来源：-,
                                               StringFormat=来源：{0}}" />
                            </Border>

                            <Border Grid.Row="10" Padding="10" CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAlarm.ClearedTime,
                                               TargetNullValue=清除时间：未清除,
                                               StringFormat=清除时间：{0:yyyy-MM-dd HH:mm:ss}}" />
                            </Border>

                            <Border Grid.Row="12" Padding="10" CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedAlarm.Message,
                                               TargetNullValue=-,
                                               FallbackValue=-,
                                               StringFormat=消息：{0}}" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ── Row 2: 分页栏 ── -->
        <Border Grid.Row="2"
                Padding="12,6"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,12,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding PageIndex, StringFormat=第 {0} 页}" />
                    <TextBlock Margin="0,0,12,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding TotalPages, StringFormat=/ 共 {0} 页}" />
                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}" Text="每页" />
                    <ComboBox Width="72" Height="28" Margin="0,0,12,0"
                              ItemsSource="{Binding PageSizes}"
                              SelectedItem="{Binding SelectedPageSize, Mode=TwoWay}" />
                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}" Text="跳转" />
                    <TextBox Width="56" Height="28" Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding JumpPageText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button MinWidth="64" Margin="0,0,8,0"
                            Command="{Binding GoPageCommand}" Content="转到" />
                    <Button MinWidth="72" Margin="0,0,8,0"
                            Command="{Binding PrevPageCommand}" Content="上一页" />
                    <Button MinWidth="72"
                            Command="{Binding NextPageCommand}" Content="下一页" />
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>