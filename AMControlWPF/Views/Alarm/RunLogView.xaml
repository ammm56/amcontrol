<UserControl x:Class="AMControlWPF.Views.Alarm.RunLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Row 0: 筛选条 ── -->
        <Border Grid.Row="0"
                Padding="12,10"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="运行日志" />
                <WrapPanel HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right">
                    <ComboBox Width="200" Height="30" Margin="0,0,8,6"
                              ItemsSource="{Binding LogFiles}"
                              SelectedItem="{Binding SelectedLogFile, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName" />
                    <TextBox Width="160" Height="30" Margin="0,0,8,6"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button MinWidth="72" Margin="0,0,8,6"
                            Command="{Binding RefreshCommand}" Content="刷新" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- ── Row 1: 主内容区 ── -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="8"   />
                <ColumnDefinition Width="*"   />
            </Grid.ColumnDefinitions>

            <!-- 左侧级别筛选栏 -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8"    />
                        <RowDefinition Height="*"    />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="级别筛选" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Levels}"
                             SelectedItem="{Binding SelectedLevel, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource ViewNavItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧日志区 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8"    />
                    <RowDefinition Height="*"    />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 统计卡片 -->
                <WrapPanel Grid.Row="0">
                    <Border Width="160" Margin="0,0,8,0" Padding="10" CornerRadius="6"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7" Foreground="{DynamicResource PrimaryTextBrush}" Text="当前条数" />
                            <TextBlock FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding TotalCount}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,0" Padding="10" CornerRadius="6"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7" Foreground="{DynamicResource PrimaryTextBrush}" Text="当前文件" />
                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       Text="{Binding SelectedLogFile.DisplayName, TargetNullValue=未选择}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- DataGrid -->
                <Border Grid.Row="2"
                        Padding="12"
                        CornerRadius="8"
                        Background="{DynamicResource SecondaryRegionBrush}">
                    <DataGrid AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Background="Transparent"
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              GridLinesVisibility="None"
                              ItemsSource="{Binding Entries}"
                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                        <DataGrid.Columns>

                            <DataGridTextColumn Header="时间" Width="110"
                                                Binding="{Binding TimeText}" />

                            <DataGridTextColumn Header="级别" Width="62"
                                                Binding="{Binding Level}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                        <Setter Property="FontWeight"  Value="SemiBold" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="FATAL">
                                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="INFO">
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="DEBUG">
                                                <Setter Property="Opacity" Value="0.65" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="TRACE">
                                                <Setter Property="Opacity" Value="0.45" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="模块" Width="80"
                                                Binding="{Binding Logger}" />

                            <DataGridTextColumn Header="消息" Width="*"
                                                Binding="{Binding Message}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- 选中行消息详情条 -->
                <Border Grid.Row="3"
                        Margin="0,6,0,0"
                        Padding="10"
                        CornerRadius="8"
                        MaxHeight="80"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <TextBlock TextWrapping="Wrap"
                               VerticalAlignment="Top"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding SelectedEntry.Message, TargetNullValue=-, FallbackValue=-}" />
                </Border>
            </Grid>
        </Grid>

        <!-- ── Row 2: 分页栏 ── -->
        <Border Grid.Row="2"
                Padding="12,6"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="{Binding TotalCount, StringFormat=共 {0} 条}" />

                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,12,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding PageIndex, StringFormat=第 {0} 页}" />
                    <TextBlock Margin="0,0,12,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding TotalPages, StringFormat=/ 共 {0} 页}" />
                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}" Text="每页" />
                    <ComboBox Width="72" Height="28" Margin="0,0,12,0"
                              ItemsSource="{Binding PageSizes}"
                              SelectedItem="{Binding SelectedPageSize, Mode=TwoWay}" />
                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}" Text="跳转" />
                    <TextBox Width="56" Height="28" Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding JumpPageText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button MinWidth="64" Margin="0,0,8,0"
                            Command="{Binding GoPageCommand}" Content="转到" />
                    <Button MinWidth="72" Margin="0,0,8,0"
                            Command="{Binding PrevPageCommand}" Content="上一页" />
                    <Button MinWidth="72"
                            Command="{Binding NextPageCommand}" Content="下一页" />
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>