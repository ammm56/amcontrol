<UserControl x:Class="AMControlWPF.Views.Am.UserManagementView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AMControlWPF.Views.Am"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Padding="12,10"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            DockPanel.Dock="Left">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="用户管理" />
                </StackPanel>

                <WrapPanel HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right">
                    <TextBox Width="160"
                             Height="30"
                             Margin="0,0,8,6"
                             VerticalContentAlignment="Center"
                             Text="搜索用户..." />
                    <Button MinWidth="72" Margin="0,0,8,6" Content="刷新" />
                    <Button MinWidth="72" Margin="0,0,8,6" Content="新增用户" />
                    <Button MinWidth="72" Margin="0,0,0,6" Content="导出" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- 主体区 -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧分组 -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="用户分组" />

                    <ListBox Grid.Row="2"
                             SelectedIndex="0"
                             ItemContainerStyle="{StaticResource ViewNavItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">全部用户</sys:String>
                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">管理员</sys:String>
                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">工程师</sys:String>
                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">操作员</sys:String>
                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">已禁用用户</sys:String>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧工作区 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 顶部统计 -->
                <WrapPanel Grid.Row="0">
                    <Border Width="160"
                            Margin="0,0,8,8"
                            Padding="10"
                            CornerRadius="6"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="用户总数" />
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="12" />
                        </StackPanel>
                    </Border>

                    <Border Width="160"
                            Margin="0,0,8,8"
                            Padding="10"
                            CornerRadius="6"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="启用用户" />
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       Text="10" />
                        </StackPanel>
                    </Border>

                    <Border Width="160"
                            Margin="0,0,8,8"
                            Padding="10"
                            CornerRadius="6"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="禁用用户" />
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DangerBrush}"
                                       Text="2" />
                        </StackPanel>
                    </Border>

                    <Border Width="180"
                            Margin="0,0,8,8"
                            Padding="10"
                            CornerRadius="6"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="当前选中用户" />
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       Text="am" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- 主区 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <!-- 用户列表 -->
                    <Border Grid.Column="0"
                            Padding="12"
                            CornerRadius="8"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="用户列表" />

                            <DataGrid Grid.Row="2"
                                      hc:DataGridAttach.CanUnselectAllWithBlankArea="True"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="None"
                                      HorizontalGridLinesBrush="Transparent"
                                      VerticalGridLinesBrush="Transparent">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="登录名" Width="100" Binding="{Binding}" />
                                    <DataGridTextColumn Header="用户名" Width="120" Binding="{Binding}" />
                                    <DataGridTextColumn Header="角色" Width="100" Binding="{Binding}" />
                                    <DataGridTextColumn Header="状态" Width="80" Binding="{Binding}" />
                                    <DataGridTextColumn Header="最后登录" Width="*" Binding="{Binding}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- 用户详情 -->
                    <Border Grid.Column="2"
                            Padding="12"
                            CornerRadius="8"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="用户详情" />

                            <Border Grid.Row="2"
                                    Padding="10"
                                    CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <hc:Gravatar Width="42"
                                                 Height="42"
                                                 Style="{StaticResource GravatarBaseStyle}"
                                                 Id="am" />

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="am" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Opacity="0.75"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="系统管理员" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="4"
                                    Padding="10"
                                    CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="角色：管理员" />
                            </Border>

                            <Border Grid.Row="6"
                                    Padding="10"
                                    CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="状态：已启用" />
                            </Border>

                            <Border Grid.Row="8"
                                    Padding="10"
                                    CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="最后登录：2026-03-18 09:20:15" />
                            </Border>

                            <Border Grid.Row="10"
                                    Padding="10"
                                    CornerRadius="6"
                                    Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="备注：系统初始化管理员账户" />
                            </Border>

                            <WrapPanel Grid.Row="12">
                                <Button MinWidth="100" Margin="0,0,8,8" Content="编辑用户" />
                                <Button MinWidth="100" Margin="0,0,8,8" Content="重置密码" />
                                <Button MinWidth="100" Margin="0,0,8,8" Content="启用/禁用" />
                                <Button MinWidth="100" Margin="0,0,8,8" Content="分配权限" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- 页内状态栏 -->
        <Border Grid.Row="2"
                Padding="12,0"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="当前模块：用户管理" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="当前角色：管理员" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>