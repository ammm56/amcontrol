<hc:GlowWindow x:Class="AMControlWPF.Views.Am.UserEditDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               Title="用户编辑"
               Width="560"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               Background="{DynamicResource RegionBrush}">

    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="16">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0"
                            Padding="20,16"
                            CornerRadius="14,14,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock x:Name="TextBlockTitle"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="新增用户" />
                    </Border>

                    <!-- 表单区（Grid 保留所有 x:Name 行定义，供代码后端控制密码行高度） -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="20,12,20,8"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition x:Name="PasswordTopSpacingRow" Height="10" />
                                <RowDefinition x:Name="PasswordLabelRow" Height="Auto" />
                                <RowDefinition x:Name="PasswordInputRow" Height="Auto" />
                                <RowDefinition x:Name="PasswordBottomSpacingRow" Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 登录名 -->
                            <StackPanel Grid.Row="0">
                                <TextBlock Margin="0,0,0,6"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="登录名" />
                                <TextBox x:Name="TextBoxLoginName"
                                         Height="36"
                                         VerticalContentAlignment="Center" />
                            </StackPanel>

                            <!-- 用户名 -->
                            <StackPanel Grid.Row="2">
                                <TextBlock Margin="0,0,0,6"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="用户名" />
                                <TextBox x:Name="TextBoxUserName"
                                         Height="36"
                                         VerticalContentAlignment="Center" />
                            </StackPanel>

                            <!-- 角色 -->
                            <StackPanel Grid.Row="4">
                                <TextBlock Margin="0,0,0,6"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="角色" />
                                <ComboBox x:Name="ComboBoxRole"
                                          Height="36"
                                          SelectedIndex="2">
                                    <ComboBoxItem Content="操作员" Tag="Operator" />
                                    <ComboBoxItem Content="工程师" Tag="Engineer" />
                                    <ComboBoxItem Content="管理员" Tag="Am" />
                                </ComboBox>
                            </StackPanel>

                            <!-- 启用账户 -->
                            <CheckBox x:Name="CheckBoxIsEnabled"
                                      Grid.Row="6"
                                      IsChecked="True"
                                      VerticalAlignment="Center"
                                      Content="启用账户" />

                            <!-- 初始密码标签（编辑模式隐藏） -->
                            <TextBlock x:Name="TextBlockPasswordLabel"
                                       Grid.Row="8"
                                       Margin="0,0,0,6"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="初始密码" />

                            <!-- 初始密码输入框（编辑模式隐藏） -->
                            <PasswordBox x:Name="PasswordBoxPassword"
                                         Grid.Row="9"
                                         Height="36"
                                         VerticalContentAlignment="Center" />

                            <!-- 备注 -->
                            <StackPanel Grid.Row="11">
                                <TextBlock Margin="0,0,0,6"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="备注" />
                                <TextBox x:Name="TextBoxRemark"
                                         Height="96"
                                         Padding="8,6"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>

                            <!-- 错误提示 -->
                            <TextBlock x:Name="TextBlockMessage"
                                       Grid.Row="13"
                                       MinHeight="22"
                                       Margin="0,4,0,4"
                                       Foreground="{DynamicResource DangerBrush}"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </ScrollViewer>

                    <!-- 底部按钮 -->
                    <Border Grid.Row="2"
                            Padding="20,12"
                            CornerRadius="0,0,13,13"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Width="80"
                                    Height="34"
                                    Click="ButtonCancel_OnClick"
                                    Content="取消" />
                            <Button Width="80"
                                    Height="34"
                                    Margin="10,0,0,0"
                                    Click="ButtonSubmit_OnClick"
                                    Content="保存" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>