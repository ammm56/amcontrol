<hc:GlowWindow x:Class="AMControlWPF.Views.Am.UserEditDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               Title="用户编辑"
               Width="560"
               Height="600"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               Background="{DynamicResource RegionBrush}">

    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="20">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TextBlockTitle"
                               Grid.Row="0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="新增用户" />

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition x:Name="PasswordTopSpacingRow" Height="10" />
                            <RowDefinition x:Name="PasswordLabelRow" Height="Auto" />
                            <RowDefinition x:Name="PasswordInputRow" Height="Auto" />
                            <RowDefinition x:Name="PasswordBottomSpacingRow" Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Margin="0,0,0,6"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="登录名" />
                            <TextBox x:Name="TextBoxLoginName"
                                     Height="36"
                                     VerticalContentAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Margin="0,0,0,6"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="用户名" />
                            <TextBox x:Name="TextBoxUserName"
                                     Height="36"
                                     VerticalContentAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Row="4">
                            <TextBlock Margin="0,0,0,6"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="角色" />
                            <ComboBox x:Name="ComboBoxRole"
                                      Height="36"
                                      SelectedIndex="2">
                                <ComboBoxItem Content="操作员" Tag="Operator" />
                                <ComboBoxItem Content="工程师" Tag="Engineer" />
                                <ComboBoxItem Content="管理员" Tag="Am" />
                            </ComboBox>
                        </StackPanel>

                        <CheckBox x:Name="CheckBoxIsEnabled"
                                  Grid.Row="6"
                                  IsChecked="True"
                                  VerticalAlignment="Center"
                                  Content="启用账户" />

                        <TextBlock x:Name="TextBlockPasswordLabel"
                                   Grid.Row="8"
                                   Margin="0,0,0,6"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="初始密码" />

                        <PasswordBox x:Name="PasswordBoxPassword"
                                     Grid.Row="9"
                                     Height="36"
                                     VerticalContentAlignment="Center" />

                        <StackPanel Grid.Row="11">
                            <TextBlock Margin="0,0,0,6"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="备注" />
                            <TextBox x:Name="TextBoxRemark"
                                     Height="96"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <TextBlock x:Name="TextBlockMessage"
                                   Grid.Row="13"
                                   MinHeight="22"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource DangerBrush}"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Width="186"
                                Height="36"
                                Click="ButtonCancel_OnClick"
                                Content="取消"
                                HorizontalAlignment="Left" />

                        <Button Grid.Column="2"
                                Width="186"
                                Height="36"
                                Click="ButtonSubmit_OnClick"
                                Content="保存"
                                HorizontalAlignment="Right" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>