<hc:GlowWindow x:Class="AMControlWPF.Views.Am.ResetUserPasswordDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               Title="重置密码"
               Width="460"
               Height="360"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               Background="{DynamicResource RegionBrush}">

    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="16">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0"
                            Padding="20,16"
                            CornerRadius="14,14,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="重置密码" />
                    </Border>

                    <!-- 表单区 -->
                    <ScrollViewer Grid.Row="1"
                                  Padding="20,16,20,8"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock x:Name="TextBlockUserInfo"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="目标用户：-" />

                            <TextBlock Margin="0,14,0,6"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="新密码" />
                            <PasswordBox x:Name="PasswordBoxNewPassword"
                                         Height="36"
                                         VerticalContentAlignment="Center"
                                         PasswordChanged="PasswordBoxNewPassword_OnPasswordChanged" />

                            <TextBlock Margin="0,12,0,6"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="确认新密码" />
                            <PasswordBox x:Name="PasswordBoxConfirmPassword"
                                         Height="36"
                                         VerticalContentAlignment="Center"
                                         PasswordChanged="PasswordBoxConfirmPassword_OnPasswordChanged" />

                            <TextBlock x:Name="TextBlockMessage"
                                       MinHeight="22"
                                       Margin="0,12,0,0"
                                       Foreground="{DynamicResource DangerBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 底部按钮 -->
                    <Border Grid.Row="2"
                            Padding="20,12"
                            CornerRadius="0,0,13,13"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Width="80"
                                    Height="34"
                                    Click="ButtonCancel_OnClick"
                                    Content="取消" />
                            <Button Width="96"
                                    Height="34"
                                    Margin="10,0,0,0"
                                    Click="ButtonSubmit_OnClick"
                                    Content="确认重置" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>