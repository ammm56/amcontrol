<hc:GlowWindow x:Class="AMControlWPF.Views.Am.ResetUserPasswordDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:AMControlWPF.Views.Am"
               mc:Ignorable="d"
               Title="重置密码"
               Width="460"
               Height="380"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               Background="{DynamicResource RegionBrush}">

    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="20">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="重置密码" />

                    <TextBlock x:Name="TextBlockUserInfo"
                               Grid.Row="2"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="目标用户：-" />

                    <TextBlock Grid.Row="3"
                               Margin="0,12,0,6"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="新密码" />
                    <PasswordBox x:Name="PasswordBoxNewPassword"
                                 Grid.Row="4"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="PasswordBoxNewPassword_OnPasswordChanged" />

                    <TextBlock Grid.Row="5"
                               Margin="0,12,0,6"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="确认新密码" />
                    <PasswordBox x:Name="PasswordBoxConfirmPassword"
                                 Grid.Row="6"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="PasswordBoxConfirmPassword_OnPasswordChanged" />

                    <TextBlock x:Name="TextBlockMessage"
                               Grid.Row="8"
                               MinHeight="22"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap" />

                    <Grid Grid.Row="9" VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Width="156"
                                Height="36"
                                Click="ButtonCancel_OnClick"
                                HorizontalAlignment="Left"
                                Content="取消" />

                        <Button Grid.Column="2"
                                Width="156"
                                Height="36"
                                Click="ButtonSubmit_OnClick"
                                HorizontalAlignment="Right"
                                Content="确认重置" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>