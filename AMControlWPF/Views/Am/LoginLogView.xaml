<UserControl x:Class="AMControlWPF.Views.Am.LoginLogView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12,10"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="登录日志" />

                <WrapPanel HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right">
                    <TextBox Width="160"
                             Height="30"
                             Margin="0,0,8,6"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <DatePicker Width="130"
                                Height="30"
                                Margin="0,0,8,6"
                                SelectedDate="{Binding StartDate, Mode=TwoWay}" />
                    <DatePicker Width="130"
                                Height="30"
                                Margin="0,0,8,6"
                                SelectedDate="{Binding EndDate, Mode=TwoWay}" />
                    <Button MinWidth="72" Margin="0,0,8,6" Command="{Binding QueryCommand}" Content="查询" />
                    <Button MinWidth="72" Margin="0,0,8,6" Command="{Binding RefreshCommand}" Content="刷新" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="日志筛选" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Filters}"
                             SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource ViewNavItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0">
                    <Border Width="160" Margin="0,0,8,8" Padding="10" CornerRadius="6" Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7" Foreground="{DynamicResource PrimaryTextBrush}" Text="日志总数" />
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Text="{Binding TotalCount}" />
                        </StackPanel>
                    </Border>

                    <Border Width="160" Margin="0,0,8,8" Padding="10" CornerRadius="6" Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7" Foreground="{DynamicResource PrimaryTextBrush}" Text="登录成功" />
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" Text="{Binding SuccessCount}" />
                        </StackPanel>
                    </Border>

                    <Border Width="160" Margin="0,0,8,8" Padding="10" CornerRadius="6" Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7" Foreground="{DynamicResource PrimaryTextBrush}" Text="登录失败" />
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource DangerBrush}" Text="{Binding FailedCount}" />
                        </StackPanel>
                    </Border>

                    <Border Width="180" Margin="0,0,8,8" Padding="10" CornerRadius="6" Background="{DynamicResource SecondaryRegionBrush}">
                        <StackPanel>
                            <TextBlock Opacity="0.7" Foreground="{DynamicResource PrimaryTextBrush}" Text="当前筛选" />
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" Text="{Binding SelectedFilter}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="12"
                            CornerRadius="8"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="登录日志列表" />

                            <DataGrid Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="None"
                                      HorizontalGridLinesBrush="Transparent"
                                      VerticalGridLinesBrush="Transparent"
                                      ItemsSource="{Binding Logs}"
                                      SelectedItem="{Binding SelectedLog, Mode=TwoWay}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="时间" Width="160" Binding="{Binding LoginTimeText}" />
                                    <DataGridTextColumn Header="登录名" Width="100" Binding="{Binding LoginName}" />
                                    <DataGridTextColumn Header="结果" Width="90" Binding="{Binding ResultText}" />
                                    <DataGridTextColumn Header="程序版本" Width="120" Binding="{Binding AppVersionText}" />
                                    <DataGridTextColumn Header="说明" Width="*" Binding="{Binding MessageText}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="12"
                            CornerRadius="8"
                            Background="{DynamicResource SecondaryRegionBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="日志详情" />

                            <Border Grid.Row="2" Padding="10" CornerRadius="6" Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedLog.LoginName, TargetNullValue=-, FallbackValue=-, StringFormat=登录名：{0}}" />
                            </Border>

                            <Border Grid.Row="4" Padding="10" CornerRadius="6" Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedLog.ResultText, TargetNullValue=-, FallbackValue=-, StringFormat=结果：{0}}" />
                            </Border>

                            <Border Grid.Row="6" Padding="10" CornerRadius="6" Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedLog.LoginTimeText, TargetNullValue=-, FallbackValue=-, StringFormat=登录时间：{0}}" />
                            </Border>

                            <Border Grid.Row="8" Padding="10" CornerRadius="6" Background="{DynamicResource RegionBrush}">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedLog.AppVersionText, TargetNullValue=-, FallbackValue=-, StringFormat=程序版本：{0}}" />
                            </Border>

                            <Border Grid.Row="10" Padding="10" CornerRadius="6" Background="{DynamicResource RegionBrush}">
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding SelectedLog.MessageText, TargetNullValue=-, FallbackValue=-, StringFormat=说明：{0}}" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Padding="12,6"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="1"
                   VerticalAlignment="Center">
                    <TextBlock Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="{Binding PageIndex, StringFormat=第 {0} 页}" />

                    <TextBlock Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="{Binding TotalPages, StringFormat=/ 共 {0} 页}" />

                    <TextBlock Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="每页" />

                    <ComboBox Width="72"
                      Height="28"
                      Margin="0,0,12,0"
                      ItemsSource="{Binding PageSizes}"
                      SelectedItem="{Binding SelectedPageSize, Mode=TwoWay}" />

                    <TextBlock Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="跳转" />

                    <TextBox Width="56"
                     Height="28"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding JumpPageText, UpdateSourceTrigger=PropertyChanged}" />

                    <Button MinWidth="64"
                    Margin="0,0,8,0"
                    Command="{Binding GoPageCommand}"
                    Content="转到" />

                    <Button MinWidth="72"
                    Margin="0,0,8,0"
                    Command="{Binding PrevPageCommand}"
                    Content="上一页" />

                    <Button MinWidth="72"
                    Command="{Binding NextPageCommand}"
                    Content="下一页" />
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>