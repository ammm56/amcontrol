<UserControl x:Class="AMControlWPF.Views.Am.UserPermissionView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="PermissionChipItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="BorderRoot"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                Background="{DynamicResource RegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderRoot" Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BorderRoot" Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PermissionToolbarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource UserPopupActionButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="MinWidth" Value="72" />
        </Style>

        <Style x:Key="PermissionTileListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左侧：用户选择 -->
        <Border Grid.Column="0"
                Padding="12"
                CornerRadius="8"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="用户选择" />

                <TextBox x:Name="TextBoxUserSearch"
                         Grid.Row="2"
                         Height="32"
                         VerticalContentAlignment="Center"
                         TextChanged="TextBoxUserSearch_OnTextChanged" />

                <ListBox x:Name="ListBoxRoleFilters"
                         Grid.Row="4"
                         SelectionChanged="ListBoxRoleFilters_SelectionChanged"
                         ItemContainerStyle="{StaticResource PermissionChipItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ListBox x:Name="ListBoxUsers"
                         Grid.Row="6"
                         SelectionChanged="ListBoxUsers_SelectionChanged"
                         ItemContainerStyle="{StaticResource ViewNavItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <hc:Gravatar Width="34"
                                             Height="34"
                                             Style="{StaticResource GravatarBaseStyle}"
                                             Id="{Binding AvatarId, TargetNullValue=guest, FallbackValue=guest}" />

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding LoginName}"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Opacity="0.75"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                               Text="{Binding RoleDisplayName}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 右侧主区 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="120" />
            </Grid.RowDefinitions>

            <!-- 顶部 -->
            <Border Grid.Row="0"
                    Padding="12,10"
                    CornerRadius="8"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="页面权限分配" />
                        <TextBlock x:Name="TextBlockSelectedUser"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Opacity="0.75"
                                   Text="未选择用户" />
                    </StackPanel>

                    <WrapPanel DockPanel.Dock="Right"
                               HorizontalAlignment="Right">
                        <Button Margin="0,0,8,0"
                                MinWidth="72"
                                Click="ButtonSelectAll_OnClick"
                                Content="全选" />
                        <Button Margin="0,0,8,0"
                                MinWidth="72"
                                Click="ButtonClearAll_OnClick"
                                Content="清空" />
                        <Button MinWidth="72" Margin="0,0,8,0"
                                Click="ButtonRefresh_OnClick"
                                Content="刷新" />
                        <Button MinWidth="72" Margin="0,0,0,0"
                                Click="ButtonSave_OnClick"
                                Content="保存" />
                    </WrapPanel>
                </DockPanel>
            </Border>

            <!-- 模块导航 -->
            <Border Grid.Row="2"
                    Padding="8"
                    CornerRadius="8"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <ListBox x:Name="ModuleNavList"
                         SelectionChanged="ModuleNavList_SelectionChanged"
                         ItemContainerStyle="{StaticResource PermissionChipItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- 磁贴权限区 -->
            <Border Grid.Row="4"
                    Padding="12"
                    CornerRadius="8"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TextBlockModuleTitle"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="页面权限" />

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="ListBoxPermissions"
                                 SelectionChanged="ListBoxPermissions_SelectionChanged"
                                 ItemContainerStyle="{StaticResource PermissionTileListBoxItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="TileRoot"
                                            Width="220"
                                            Height="168"
                                            Padding="12"
                                            CornerRadius="8"
                                            Background="{DynamicResource RegionBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            Effect="{StaticResource EffectShadow1}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <DockPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                                <CheckBox x:Name="TileCheckBox"
                                                          DockPanel.Dock="Right"
                                                          Margin="8,0,0,0"
                                                          IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                                            </DockPanel>

                                            <TextBlock Grid.Row="1"
                                                       Margin="0,8,0,0"
                                                       FontSize="12"
                                                       Opacity="0.75"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding Description}" />

                                            <TextBlock Grid.Row="2"
                                                       Margin="0,8,0,0"
                                                       FontSize="11"
                                                       Opacity="0.75"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding RecommendedRoles, StringFormat=建议角色：{0}}" />

                                            <Border x:Name="RiskBadge"
                                                    Grid.Row="3"
                                                    Margin="0,8,0,0"
                                                    HorizontalAlignment="Left"
                                                    Padding="8,3"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource SecondaryRegionBrush}">
                                                <TextBlock x:Name="RiskBadgeText"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           FontSize="11"
                                                           Text="{Binding RiskLevel, StringFormat=风险：{0}}" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="TileRoot" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TileRoot" Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                            <Setter TargetName="TileRoot" Property="Effect" Value="{StaticResource EffectShadow4}" />
                                        </Trigger>

                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                            <Setter TargetName="TileRoot" Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                        </DataTrigger>

                                        <Trigger SourceName="TileCheckBox" Property="IsChecked" Value="True">
                                            <Setter TargetName="TileRoot" Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                            <Setter TargetName="TileRoot" Property="Effect" Value="{StaticResource EffectShadow4}" />
                                        </Trigger>

                                        <DataTrigger Binding="{Binding RiskLevel}" Value="高">
                                            <Setter TargetName="RiskBadge" Property="Background" Value="{DynamicResource DangerBrush}" />
                                            <Setter TargetName="RiskBadgeText" Property="Foreground" Value="White" />
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding RiskLevel}" Value="中">
                                            <Setter TargetName="RiskBadge" Property="Background" Value="{DynamicResource WarningBrush}" />
                                            <Setter TargetName="RiskBadgeText" Property="Foreground" Value="White" />
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding RiskLevel}" Value="低">
                                            <Setter TargetName="RiskBadge" Property="Background" Value="{DynamicResource SuccessBrush}" />
                                            <Setter TargetName="RiskBadgeText" Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 底部：仅保留详情说明 -->
            <Border Grid.Row="6"
                    Padding="12"
                    CornerRadius="8"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="权限说明" />

                    <Border Grid.Row="2"
                            Padding="10"
                            CornerRadius="6"
                            Background="{DynamicResource RegionBrush}">
                        <TextBlock x:Name="TextBlockPermissionDescription"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="请选择一个权限磁贴查看说明。" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>