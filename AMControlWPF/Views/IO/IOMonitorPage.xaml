<UserControl x:Class="AMControlWPF.Views.IO.IOMonitorPage"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AMControlWPF.Views.IO"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12,0"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            DockPanel.Dock="Left">
                    <Path Width="18"
                          Height="18"
                          Margin="0,0,8,0"
                          Stretch="Uniform"
                          Fill="{DynamicResource PrimaryBrush}"
                          Data="{StaticResource KeyboardGeometry}" />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="IO 监视" />
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Opacity="0.7"
                               Text="输入输出点状态、筛选、分组与调试观察" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            DockPanel.Dock="Right">
                    <TextBox Width="180"
                             Height="30"
                             Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             Text="搜索点位..." />
                    <Button MinWidth="80" Margin="0,0,8,0" Content="刷新" />
                    <Button MinWidth="80" Margin="0,0,8,0" Content="全部展开" />
                    <Button MinWidth="80" Content="导出" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,8,0,8"
                Padding="8,6"
                CornerRadius="8"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <TabControl Background="Transparent"
                        BorderThickness="0">
                <TabItem Header="DI 监视" />
                <TabItem Header="DO 监视" />
                <TabItem Header="映射关系" />
                <TabItem Header="调试记录" />
            </TabControl>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,8,0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="点位分组" />

                    <ListBox Grid.Row="2"
                             SelectedIndex="0">
                        <ListBoxItem Content="全部点位" />
                        <ListBoxItem Content="输入 DI" />
                        <ListBoxItem Content="输出 DO" />
                        <ListBoxItem Content="启动/停止按钮" />
                        <ListBoxItem Content="气缸与电磁阀" />
                        <ListBoxItem Content="安全信号" />
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="12"
                        CornerRadius="8"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="点位监视" />

                        <DataGrid Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="逻辑点位" Width="90" Binding="{Binding}" />
                                <DataGridTextColumn Header="名称" Width="180" Binding="{Binding}" />
                                <DataGridTextColumn Header="类型" Width="80" Binding="{Binding}" />
                                <DataGridTextColumn Header="卡号" Width="70" Binding="{Binding}" />
                                <DataGridTextColumn Header="通道" Width="70" Binding="{Binding}" />
                                <DataGridTextColumn Header="状态" Width="80" Binding="{Binding}" />
                                <DataGridTextColumn Header="更新时间" Width="*" Binding="{Binding}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,8,0,0"
                        Padding="12"
                        CornerRadius="8"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="快速状态" />

                        <UniformGrid Grid.Row="2" Columns="4">
                            <Border Margin="0,0,8,0"
                                    Padding="10"
                                    Background="{DynamicResource SecondaryRegionBrush}"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Opacity="0.7"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="DI 总数" />
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="64" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,8,0"
                                    Padding="10"
                                    Background="{DynamicResource SecondaryRegionBrush}"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Opacity="0.7"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="DO 总数" />
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="48" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,8,0"
                                    Padding="10"
                                    Background="{DynamicResource SecondaryRegionBrush}"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Opacity="0.7"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="当前激活输入" />
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               Text="5" />
                                </StackPanel>
                            </Border>

                            <Border Padding="10"
                                    Background="{DynamicResource SecondaryRegionBrush}"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Opacity="0.7"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="当前激活输出" />
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               Text="3" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2"
                    Padding="12"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="点位详情" />

                    <StackPanel Grid.Row="2">
                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6">
                            <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="当前点位：DI-001" />
                        </Border>

                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6">
                            <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="名称：启动按钮" />
                        </Border>

                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6">
                            <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="类型：数字输入" />
                        </Border>

                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6">
                            <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="卡号：0 / 通道：1" />
                        </Border>

                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="当前状态" />
                                <TextBlock Grid.Column="1"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           FontWeight="SemiBold"
                                           Text="ON" />
                            </Grid>
                        </Border>

                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6">
                            <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="更新时间：22:35:18.256" />
                        </Border>

                        <Border Padding="10"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="调试操作" />
                                <Button Height="32" Margin="0,0,0,8" Content="定位到映射配置" />
                                <Button Height="32" Content="跳转到调试页" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,8,0,0"
                Padding="12,0"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="最后刷新：2026-03-17 22:35:18" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="当前分组：输入 DI" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
