<UserControl x:Class="AMControlWPF.Views.IO.IOMonitorView"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AMControlWPF.Views.IO"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0"
                Padding="12,10"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            DockPanel.Dock="Left">
                    <Path Width="18"
                          Height="18"
                          Margin="0,0,8,0"
                          Stretch="Uniform"
                          Fill="{DynamicResource PrimaryBrush}"
                          Data="{StaticResource KeyboardGeometry}" />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="点位筛选与操作" />
                </StackPanel>

                <WrapPanel HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right">
                    <TextBox Width="150"
                             Height="30"
                             Margin="0,0,8,6"
                             VerticalContentAlignment="Center"
                             Text="搜索点位..." />
                    <Button MinWidth="72" Margin="0,0,8,6" Content="刷新" />
                    <Button MinWidth="72" Margin="0,0,8,6" Content="全部展开" />
                    <Button MinWidth="72" Margin="0,0,0,6" Content="导出" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- 主体区 -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧分组 -->
            <Border Grid.Column="0"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="点位分组" />

                    <ListBox Grid.Row="2"
                             SelectedIndex="0">
                        <ListBoxItem Content="全部点位" />
                        <ListBoxItem Content="启动/停止按钮" />
                        <ListBoxItem Content="气缸与电磁阀" />
                        <ListBoxItem Content="安全信号" />
                        <ListBoxItem Content="相机相关" />
                        <ListBoxItem Content="PLC 联动" />
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧单页工作区 -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 当前分组标题 -->
                    <Border Grid.Row="0"
                            Padding="12,10"
                            CornerRadius="8"
                            Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Left"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="当前分组：" />
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           Text="启动/停止按钮" />
                            </StackPanel>

                            <TextBlock DockPanel.Dock="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Opacity="0.75"
                                       Text="模式：监视 / 通讯状态：OK" />
                        </DockPanel>
                    </Border>

                    <!-- 顶部统计 -->
                    <WrapPanel Grid.Row="2">
                        <Border Width="160"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="点位总数" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="64" />
                            </StackPanel>
                        </Border>

                        <Border Width="160"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="当前激活点位" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Text="5" />
                            </StackPanel>
                        </Border>

                        <Border Width="160"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="通讯状态" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Text="OK" />
                            </StackPanel>
                        </Border>

                        <Border Width="160"
                                Margin="0,0,8,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <StackPanel>
                                <TextBlock Opacity="0.7"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="当前点位" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           Text="DI-001" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- 主区 -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="220" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="240" />
                            </Grid.ColumnDefinitions>

                            <!-- 点位列表 -->
                            <Border Grid.Column="0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="{DynamicResource SecondaryRegionBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="点位监视" />

                                    <DataGrid Grid.Row="2"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="逻辑点位" Width="90" Binding="{Binding}" />
                                            <DataGridTextColumn Header="名称" Width="180" Binding="{Binding}" />
                                            <DataGridTextColumn Header="类型" Width="80" Binding="{Binding}" />
                                            <DataGridTextColumn Header="卡号" Width="70" Binding="{Binding}" />
                                            <DataGridTextColumn Header="通道" Width="70" Binding="{Binding}" />
                                            <DataGridTextColumn Header="状态" Width="80" Binding="{Binding}" />
                                            <DataGridTextColumn Header="更新时间" Width="*" Binding="{Binding}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <!-- 点位详情 -->
                            <Border Grid.Column="2"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="{DynamicResource SecondaryRegionBrush}">
                                <StackPanel>
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="点位详情" />

                                    <Border Margin="0,12,0,8"
                                            Padding="10"
                                            CornerRadius="6"
                                            Background="{DynamicResource RegionBrush}">
                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="当前点位：DI-001" />
                                    </Border>

                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="6"
                                            Background="{DynamicResource RegionBrush}">
                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="名称：启动按钮" />
                                    </Border>

                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="6"
                                            Background="{DynamicResource RegionBrush}">
                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="类型：数字输入" />
                                    </Border>

                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="6"
                                            Background="{DynamicResource RegionBrush}">
                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="卡号：0 / 通道：1" />
                                    </Border>

                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="6"
                                            Background="{DynamicResource RegionBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="当前状态" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{DynamicResource SuccessBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="ON" />
                                        </Grid>
                                    </Border>

                                    <Border Padding="10"
                                            CornerRadius="6"
                                            Background="{DynamicResource RegionBrush}">
                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}" Text="更新时间：22:35:18.256" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 底部调试记录 -->
                        <Border Grid.Row="2"
                                Padding="12"
                                CornerRadius="8"
                                Background="{DynamicResource SecondaryRegionBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="调试记录" />

                                <DataGrid Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          CanUserAddRows="False"
                                          IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="时间" Width="180" Binding="{Binding}" />
                                        <DataGridTextColumn Header="点位" Width="100" Binding="{Binding}" />
                                        <DataGridTextColumn Header="操作" Width="120" Binding="{Binding}" />
                                        <DataGridTextColumn Header="结果" Width="100" Binding="{Binding}" />
                                        <DataGridTextColumn Header="内容" Width="*" Binding="{Binding}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- 页内状态栏 -->
        <Border Grid.Row="2"
                Padding="12,0"
                CornerRadius="8"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="最后刷新：2026-03-17 22:35:18" />
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="当前分组：启动/停止按钮" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>