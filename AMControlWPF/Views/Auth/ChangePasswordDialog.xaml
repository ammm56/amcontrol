<hc:GlowWindow x:Class="AMControlWPF.Views.Auth.ChangePasswordDialog"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:AMControlWPF.Views.Auth"
               mc:Ignorable="d"
               Title="修改密码"
               Width="500"
               Height="440"
               ResizeMode="NoResize"
               ShowNonClientArea="False"
               WindowStartupLocation="CenterOwner"
               KeyDown="ChangePasswordDialog_OnKeyDown"
               Background="{DynamicResource RegionBrush}">

    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="20">
            <Border CornerRadius="14"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow4}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="修改密码" />

                    <TextBlock Grid.Row="2"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="旧密码" />
                    <PasswordBox x:Name="PasswordBoxOld"
                                 Grid.Row="3"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="PasswordBoxOld_OnPasswordChanged" />

                    <TextBlock Grid.Row="5"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="新密码" />
                    <PasswordBox x:Name="PasswordBoxNew"
                                 Grid.Row="6"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="PasswordBoxNew_OnPasswordChanged" />

                    <TextBlock Grid.Row="8"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="确认新密码" />
                    <PasswordBox x:Name="PasswordBoxConfirm"
                                 Grid.Row="9"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="PasswordBoxConfirm_OnPasswordChanged" />

                    <TextBlock x:Name="TextBlockMessage"
                               Grid.Row="11"
                               MinHeight="22"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap" />

                    <Grid Grid.Row="13" VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Width="166"
                                Height="36"
                                Click="ButtonCancel_OnClick"
                                Content="取消" HorizontalAlignment="Left" />

                        <Button Grid.Column="2"
                                Width="166"
                                Height="36"
                                Click="ButtonSubmit_OnClick"
                                Content="提交修改" HorizontalAlignment="Right" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>