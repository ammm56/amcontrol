<Window x:Class="AMControlWPF.CfgInfo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AMControlWPF"
        mc:Ignorable="d"
        Title="CfgInfo" Height="450" Width="800">
    <Grid>
        <StackPanel DataContext="{Binding Sqlite}">
            <TextBox x:Name="tb_cfginfo" Text="{Binding Connection,Mode=OneWay}" VerticalAlignment="Top"/>
            
            <!-- 这里的 Binding 直接写属性名即可 -->
            <TextBlock Text="连接字符串:"/>
            <TextBox Text="{Binding Connection, Mode=TwoWay}"/>

            <TextBlock Text="启用:"/>
            <TextBox Text="{Binding Enabled, Mode=TwoWay}"/>
        </StackPanel>

    </Grid>
</Window>
