<Window x:Class="AMControlWPF.AxisTableInfo"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AMControlWPF"
        mc:Ignorable="d"
        Title="AxisTableInfo" Height="450" Width="800">
    <Grid>
        <!--<TextBox Text="{Binding message}" 
         TextWrapping="Wrap" 
         AcceptsReturn="True" 
         VerticalScrollBarVisibility="Auto"/>-->
        
        <!--<DataGrid x:Name="dg_axis" AutoGenerateColumns="False" ItemsSource="{Binding data}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="编号" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="轴号" Binding="{Binding Axis, StringFormat={}{0}轴}"/>
                <DataGridTextColumn Header="参数名称" Binding="{Binding ParamName_Cn}"/>
                <DataGridTextColumn Header="设定值" Binding="{Binding ParamSetVal}"/>
                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>-->

        <DataGrid x:Name="dg_axis" 
          ItemsSource="{Binding Items}" 
          SelectedItem="{Binding Item, Mode=TwoWay}"
          AutoGenerateColumns="False"
          HeadersVisibility="All" 
          RowHeaderWidth="50"
          IsReadOnly="True" 
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          SelectionMode="Single"
          GridLinesVisibility="Horizontal"
          hc:DataGridAttach.ShowRowNumber="True" 
          Background="{DynamicResource RegionBrush}"
          Style="{StaticResource DataGrid.Small}" SelectionChanged="dg_axis_SelectionChanged">

            <!-- 1. 行表头：保持 CheckBox 勾选状态（仅展示用） -->
            <DataGrid.RowHeaderTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                      IsHitTestVisible="False"
                      HorizontalAlignment="Center"/>
                </DataTemplate>
            </DataGrid.RowHeaderTemplate>

            <DataGrid.Columns>
                <!-- 2. 编号 -->
                <DataGridTextColumn Header="编号" 
                            Binding="{Binding Id, Mode=OneWay}" 
                            Width="60"/>

                <!-- 3. 轴号（带图标展示） -->
                <DataGridTemplateColumn Header="轴号" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <!-- 使用 HandyControl 内置图标 -->
                                <Path Data="{StaticResource WindowsGeometry}" 
                              Fill="{DynamicResource PrimaryBrush}" 
                              Width="12" Height="12" Stretch="Uniform" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Axis, StringFormat={}{0}轴, Mode=OneWay}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 4. 参数名称 -->
                <DataGridTextColumn Header="参数名称" 
                            Binding="{Binding ParamName_Cn, Mode=OneWay}" 
                            Width="150"
                            FontWeight="SemiBold"/>

                <!-- 5. 设定值：纯文本展示 -->
                <DataGridTextColumn Header="设定值" 
                            Binding="{Binding ParamSetVal, Mode=OneWay}" 
                            Width="100"
                            ElementStyle="{StaticResource TextBlockDefault}">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}">
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>

                <!-- 6. 描述：自动换行展示 -->
                <DataGridTextColumn Header="描述" 
                            Binding="{Binding Description, Mode=OneWay}" 
                            Width="*" 
                            ElementStyle="{StaticResource TextBlockDefault}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 1. 在界面合适位置定义抽屉 -->
        <hc:Drawer x:Name="DrawerConfig" 
           IsOpen="{Binding IsDrawerOpen}" 
           Dock="Right" 
           ShowMask="True"
           Width="300">
            <!-- 设置抽屉滑出后的宽度 -->

            <Border Background="{DynamicResource RegionBrush}" Padding="20">
                <StackPanel>
                    <TextBlock Text="轴参数详情" Style="{StaticResource TextBlockTitleBold}"/>
                    <hc:Divider Margin="0,10"/>

                    <!-- 绑定你之前 DataGrid 选中的那个 item -->
                    <hc:TextBox hc:TitleElement.Title="当前轴名" Text="{Binding item.Name}" IsReadOnly="True"/>
                    <hc:TextBox hc:TitleElement.Title="当前位置" Text="{Binding item.CurrentPos}" Margin="0,10"/>

                    <Button Content="关闭抽屉" Margin="0,20"/>
                </StackPanel>
            </Border>
        </hc:Drawer>
        
    </Grid>
</Window>
