<Window x:Class="AMControlWPF.GSNA"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AMControlWPF"
        mc:Ignorable="d"
        Title="GSNA" Height="600" Width="1280">
    <Grid x:Name="grid_a">
        <Button x:Name="btn_init" Content="1初始化" HorizontalAlignment="Left" Margin="21,19,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top"/>
        <Button x:Name="btn_connect" Content="2连接卡" HorizontalAlignment="Left" Margin="173,19,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_connect_Click"/>
        <Button x:Name="btn_clearstatus" Content="3清除状态" HorizontalAlignment="Left" Margin="21,89,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_clearstatus_Click"/>
        <Button x:Name="btn_enable" Content="4使能" HorizontalAlignment="Left" Margin="21,159,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_enable_Click"/>
        <Button x:Name="btn_pointclearzero" Content="5位置清零" HorizontalAlignment="Left" Margin="21,229,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_pointclearzero_Click"/>
        <Button x:Name="btn_runstaart" Content="6开始运动" HorizontalAlignment="Left" Margin="21,299,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_runstaart_Click"/>
        <Button x:Name="btn_runstop" Content="7停止运动" HorizontalAlignment="Left" Margin="21,369,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_runstop_Click"/>
        <Button x:Name="btn_configaxisarg" Content="手动配置参数" HorizontalAlignment="Left" Margin="173,89,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_configaxisarg_Click"/>
        <Button x:Name="btn_clearoutinfo" Content="清除输出信息" HorizontalAlignment="Left" Margin="173,369,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_clearoutinfo_Click"/>
        <Button x:Name="btn_stopall" Content="急停" HorizontalAlignment="Left" Margin="325,369,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_stopall_Click" />

        <Button x:Name="btn_jogmoveZmm" Content="Jog正向移动(mm)" HorizontalAlignment="Left" Margin="531,299,0,0" Height="55" Width="192" FontSize="22" VerticalAlignment="Top" MouseUp="btn_jogmoveZmm_MouseUp" MouseDown="btn_jogmoveZmm_MouseDown" />
        <Button x:Name="btn_jogmoveFmm" Content="Jog负向移动(mm)" HorizontalAlignment="Left" Margin="325,299,0,0" Height="55" Width="192" FontSize="22" VerticalAlignment="Top" MouseUp="btn_jogmoveZmm_MouseUp" MouseDown="btn_jogmoveFmm_MouseDown" />

        <TextBox x:Name="tb_statusinfo"  Text="状态信息" FontSize="18" VerticalAlignment="Top" Height="161" Margin="0,430,0,0" TextChanged="tb_statusinfo_TextChanged" />


    </Grid>
</Window>
