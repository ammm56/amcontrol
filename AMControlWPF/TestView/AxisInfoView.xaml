<Window x:Class="AMControlWPF.TestView.AxisInfoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AMControlWPF.TestView"
        mc:Ignorable="d"
        Title="AxisInfoView" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid ItemsSource="{Binding AxisParams}"
                  SelectedItem="{Binding SelectedAxisParam}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="轴号" Binding="{Binding Axis}" />
                <DataGridTextColumn Header="参数名" Binding="{Binding ParamName}" />
                <DataGridTextColumn Header="参数值" Binding="{Binding ParamSetVal}" />
                <DataGridTextColumn Header="描述" Binding="{Binding Description}" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="80" Margin="5"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding SelectedAxisParam}" />
            <Button Content="删除" Width="80" Margin="5"
                    Command="{Binding DeleteCommand}"
                    CommandParameter="{Binding SelectedAxisParam}" />
            <Button Content="刷新" Width="80" Margin="5"
                    Command="{Binding LoadCommand}" />
        </StackPanel>
    </Grid>
</Window>
