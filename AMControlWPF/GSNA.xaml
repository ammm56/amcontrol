<Window x:Class="AMControlWPF.GSNA"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AMControlWPF"
        mc:Ignorable="d"
        Title="GSNA" Height="600" Width="1280">
    <Grid x:Name="grid_a">
        <Button x:Name="btn_init" Content="初始化" HorizontalAlignment="Left" Margin="21,19,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top"/>
        <Button x:Name="btn_clearstatus" Content="清除状态" HorizontalAlignment="Left" Margin="21,89,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_clearstatus_Click"/>
        <Button x:Name="btn_enable" Content="使能" HorizontalAlignment="Left" Margin="21,159,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_enable_Click"/>
        <Button x:Name="btn_pointclearzero" Content="位置清零" HorizontalAlignment="Left" Margin="21,229,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_pointclearzero_Click"/>
        <Button x:Name="btn_runstaart" Content="开始运动" HorizontalAlignment="Left" Margin="21,299,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_runstaart_Click"/>
        <Button x:Name="btn_runstop" Content="停止运动" HorizontalAlignment="Left" Margin="21,369,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top" Click="btn_runstop_Click"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="21,449,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="21,519,0,0" Height="55" Width="135" FontSize="22" VerticalAlignment="Top"/>
        <TextBlock x:Name="tb_statusinfo"  Text="状态信息" HorizontalAlignment="Left" Margin="935,0,0,0" Width="360" FontSize="18" />


    </Grid>
</Window>
