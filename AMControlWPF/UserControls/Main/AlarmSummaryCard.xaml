<UserControl x:Class="AMControlWPF.UserControls.Main.AlarmSummaryCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <Border Padding="12"
            CornerRadius="10"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="SummaryHeaderRow" Height="Auto" />
                <RowDefinition x:Name="SummaryStatRow" Height="Auto" />
                <RowDefinition x:Name="SummaryListRow" Height="*" />
                <RowDefinition x:Name="SummaryActionRow" Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="报警摘要" />

                <Button DockPanel.Dock="Right"
                        MinWidth="88"
                        Click="ButtonOpen_OnClick"
                        Content="打开报警中心" />
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="10"
                        CornerRadius="8"
                        Background="{DynamicResource SecondaryRegionBrush}">
                    <StackPanel>
                        <TextBlock Opacity="0.75"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="当前活动报警" />
                        <TextBlock x:Name="TextBlockAlarmCount"
                                   Margin="0,6,0,0"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DangerBrush}"
                                   Text="0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="10"
                        CornerRadius="8"
                        Background="{DynamicResource SecondaryRegionBrush}">
                    <StackPanel>
                        <TextBlock Opacity="0.75"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="严重报警" />
                        <TextBlock x:Name="TextBlockCriticalCount"
                                   Margin="0,6,0,0"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DangerBrush}"
                                   Text="0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Padding="10"
                    CornerRadius="8"
                    Background="{DynamicResource SecondaryRegionBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="最近报警" />

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <TextBlock x:Name="TextBlockEmptyState"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Opacity="0.65"
                                   Text="当前无活动报警"
                                   Visibility="Collapsed" />

                        <ItemsControl x:Name="ItemsControlRecentAlarms">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="8"
                                            CornerRadius="6"
                                            Background="{DynamicResource RegionBrush}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Message}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Opacity="0.75"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Text="{Binding SummaryText}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </Border>

            <DockPanel Grid.Row="3" Margin="0,10,0,0" LastChildFill="False">
                <Button DockPanel.Dock="Right"
                        MinWidth="72"
                        Click="ButtonRefresh_OnClick"
                        Content="刷新" />
            </DockPanel>
        </Grid>
    </Border>
</UserControl>