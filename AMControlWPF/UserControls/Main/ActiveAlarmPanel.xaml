<UserControl x:Class="AMControlWPF.UserControls.Main.ActiveAlarmPanel"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="AlarmBannerRow" Height="Auto" />
            <RowDefinition x:Name="AlarmToolbarRow" Height="Auto" />
            <RowDefinition x:Name="AlarmContentRow" Height="*" />
            <RowDefinition x:Name="AlarmPagingRow" Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="BorderCriticalBanner"
                Grid.Row="0"
                Margin="0,0,0,10"
                Padding="10,8"
                CornerRadius="8"
                Background="{DynamicResource DangerBrush}"
                Visibility="Collapsed">
            <TextBlock x:Name="TextBlockCriticalBanner"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="存在高等级报警，请立即处理。" />
        </Border>

        <DockPanel Grid.Row="1" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="活动报警" />

                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Opacity="0.75"
                           Text="总数：" />

                <TextBlock x:Name="TextBlockAlarmCount"
                           Margin="4,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DangerBrush}"
                           Text="0" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Margin="0,0,8,0"
                        MinWidth="72"
                        Click="ButtonRefresh_OnClick"
                        Content="刷新" />

                <Button Margin="0,0,8,0"
                        MinWidth="88"
                        Click="ButtonClearCurrent_OnClick"
                        Content="清除当前" />

                <Button MinWidth="88"
                        Click="ButtonClearAll_OnClick"
                        Content="全部清除" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="AlarmTableColumn" Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition x:Name="AlarmDetailColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="8"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <DataGrid x:Name="DataGridActiveAlarms"
                          SelectionChanged="DataGridActiveAlarms_SelectionChanged"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowHeaderWidth="0"
                          BorderThickness="0"
                          Background="Transparent"
                          AlternatingRowBackground="{DynamicResource RegionBrush}"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间"
                                            Width="150"
                                            Binding="{Binding TimeText}" />
                        <DataGridTextColumn Header="等级"
                                            Width="72"
                                            Binding="{Binding LevelText}" />
                        <DataGridTextColumn Header="代码"
                                            Width="110"
                                            Binding="{Binding CodeText}" />
                        <DataGridTextColumn Header="来源"
                                            Width="100"
                                            Binding="{Binding SourceDisplay}" />
                        <DataGridTextColumn Header="消息"
                                            Width="*"
                                            Binding="{Binding Message}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2"
                    CornerRadius="8"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="报警详情" />

                        <Border Margin="0,10,0,0"
                                Padding="10"
                                CornerRadius="8"
                                Background="{DynamicResource RegionBrush}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="消息" />
                                <TextBlock x:Name="TextBlockAlarmDetailMessage"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="-" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,10,0,0"
                                Padding="10"
                                CornerRadius="8"
                                Background="{DynamicResource RegionBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="TextBlockAlarmDetailCode"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="报警代码：-" />

                                <TextBlock x:Name="TextBlockAlarmDetailLevel"
                                           Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="报警等级：-" />

                                <TextBlock x:Name="TextBlockAlarmDetailSource"
                                           Grid.Row="2"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="报警来源：-" />

                                <TextBlock x:Name="TextBlockAlarmDetailCardId"
                                           Grid.Row="3"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="控制卡号：-" />

                                <TextBlock x:Name="TextBlockAlarmDetailTime"
                                           Grid.Row="4"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="报警时间：-" />
                            </Grid>
                        </Border>

                        <Border Margin="0,10,0,0"
                                Padding="10"
                                CornerRadius="8"
                                Background="{DynamicResource RegionBrush}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="详细说明" />
                                <TextBlock x:Name="TextBlockAlarmDetailDescription"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="-" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,10,0,0"
                                Padding="10"
                                CornerRadius="8"
                                Background="{DynamicResource RegionBrush}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="处理建议" />
                                <TextBlock x:Name="TextBlockAlarmDetailSuggestion"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="-" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,10,0,0" LastChildFill="False">
            <TextBlock x:Name="TextBlockPageRange"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Opacity="0.75"
                       Text="0 / 0" />

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button x:Name="ButtonPrevPage"
                        Width="78"
                        Click="ButtonPrevPage_OnClick"
                        Content="上一页" />

                <TextBlock x:Name="TextBlockPageInfo"
                           Margin="12,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="第 0 / 0 页" />

                <Button x:Name="ButtonNextPage"
                        Width="78"
                        Click="ButtonNextPage_OnClick"
                        Content="下一页" />
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>