<hc:GlowWindow x:Class="AMControlWPF.MainWindow"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               ResizeMode="CanResizeWithGrip"
               ShowNonClientArea="True"
               WindowStartupLocation="CenterScreen"
               Background="{DynamicResource RegionBrush}"
               xmlns:local="clr-namespace:AMControlWPF"
               xmlns:main="clr-namespace:AMControlWPF.UserControl.Main"
               mc:Ignorable="d"
               Title="AM运动控制"
               Icon="/Resources/Img/logo.ico"
               Height="800"
               Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 一级导航 -->
            <Border Grid.Column="0"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
                <ListBox x:Name="PrimaryNavList"
                     SelectionChanged="PrimaryNavList_SelectionChanged"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="8,6"
                                Padding="8,10"
                                CornerRadius="6"
                                Background="Transparent">
                                <TextBlock Text="{Binding DisplayName}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- 二级导航 -->
            <Border Grid.Column="1"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                        Padding="16,0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Background="{DynamicResource SecondaryRegionBrush}">
                        <TextBlock x:Name="TextBlockPrimaryTitle"
                               VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="首页" />
                    </Border>

                    <ListBox x:Name="SecondaryNavList"
                         Grid.Row="1"
                         SelectionChanged="SecondaryNavList_SelectionChanged"
                         Background="Transparent"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="10,6"
                                    Padding="12,10"
                                    CornerRadius="6"
                                    Background="Transparent">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Opacity="0.75"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding Description}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧工作区 -->
            <Grid Grid.Column="2" Background="{DynamicResource RegionBrush}">
                <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent" />
            </Grid>
        </Grid>

        <!-- 全局状态栏 -->
        <Border Grid.Row="1"
            Padding="12,0"
            Background="{DynamicResource SecondaryRegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="系统就绪" />

                <TextBlock Grid.Column="1"
                       Margin="0,0,16,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="Motion: 已连接" />

                <TextBlock Grid.Column="2"
                       Margin="0,0,16,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="PLC: 已连接" />

                <TextBlock Grid.Column="3"
                       Margin="0,0,16,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="Camera: 已连接" />

                <TextBlock Grid.Column="4"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DangerBrush}"
                       Text="报警: 0" />
            </Grid>
        </Border>
    </Grid>
</hc:GlowWindow>
