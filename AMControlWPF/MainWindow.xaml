<Window x:Class="AMControlWPF.MainWindow"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AMControlWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <TextBox  Text="测试" Style="{StaticResource TextBoxBaseStyle}" hc:BorderElement.CornerRadius="5" FontSize="36" x:Name="tb_test1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Button x:Name="btn_loadcfg" Content="载入配置" Style="{StaticResource ButtonPrimary}" hc:BorderElement.CornerRadius="5" HorizontalAlignment="Left" Margin="31,21,0,0" VerticalAlignment="Top" Height="55" Width="135" FontSize="22" Click="btn_loadcfg_Click"/>
        <Button x:Name="btn_querydbaxistable" Content="读取轴表记录" Style="{StaticResource ButtonPrimary}" hc:BorderElement.CornerRadius="5" HorizontalAlignment="Left" Margin="180,21,0,0" VerticalAlignment="Top" Height="55" Width="173" FontSize="22" Click="btn_querydbaxistable_Click" />
        <Button x:Name="btn_randomcfgval" Content="随机修改配置值" Style="{StaticResource ButtonPrimary}" hc:BorderElement.CornerRadius="5" HorizontalAlignment="Left" Margin="367,21,0,0" VerticalAlignment="Top" Height="55" Width="200" FontSize="22" Click="btn_randomcfgval_Click" />

        <Button x:Name="btn_gsna" Content="GSNA" Style="{StaticResource ButtonPrimary}" hc:BorderElement.CornerRadius="5" HorizontalAlignment="Left" Margin="31,91,0,0" VerticalAlignment="Top" Height="55" Width="135" FontSize="22" Click="btn_gsna_Click" />

        <Button x:Name="btn_handya" Content="HandyA" Style="{StaticResource ButtonPrimary}" hc:BorderElement.CornerRadius="5" HorizontalAlignment="Left" Margin="180,91,0,0" VerticalAlignment="Top" Height="55" Width="135" FontSize="22" Click="btn_handya_Click" />


    </Grid>
</Window>
