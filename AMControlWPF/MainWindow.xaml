<hc:GlowWindow x:Class="AMControlWPF.MainWindow"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:AMControlWPF"
               xmlns:main="clr-namespace:AMControlWPF.UserControls.Main"
               mc:Ignorable="d"
               ResizeMode="CanResizeWithGrip"
               ShowNonClientArea="True"
               WindowStartupLocation="CenterScreen"
               Background="{DynamicResource RegionBrush}"
               Title="AM运动控制"
               Icon="/Resources/Img/logo.ico"
               Height="1024"
               Width="1280">
    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="16,16,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 一级导航模块 -->
                <Border Grid.Column="0"
                        Margin="0,0,12,0"
                        Padding="8,12"
                        CornerRadius="14"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Effect="{StaticResource EffectShadow2}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox x:Name="PrimaryNavList"
                                 Grid.Row="0"
                                 SelectionChanged="PrimaryNavList_SelectionChanged"
                                 ItemContainerStyle="{StaticResource PrimaryNavItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- 一级导航模块 底部的用户卡片 -->
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Button x:Name="ButtonUserCard"
                                    Width="60" Height="60" 
                                    Click="ButtonUserCard_OnClick"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Cursor="Hand">
                                <Border Padding="6,6"
                                        CornerRadius="10"
                                        Background="{DynamicResource SecondaryRegionBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center">
                                        <hc:Gravatar x:Name="GravatarCurrentUser"  Width="50" Height="50" Style="{StaticResource BaseStyle}" Id="am" />
                                    </StackPanel>
                                </Border>
                            </Button>

                            <Popup x:Name="PopupUserMenu"
                                   PlacementTarget="{Binding ElementName=ButtonUserCard}"
                                   Placement="Top"
                                   VerticalOffset="-6"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border Width="188"
                                        Padding="8"
                                        CornerRadius="10"
                                        Background="{DynamicResource RegionBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Effect="{StaticResource EffectShadow4}">
                                    <StackPanel>
                                        <TextBlock x:Name="TextBlockPopupUserTitle"
                                                   Margin="8,6,8,10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="当前用户 / 角色" />

                                        <Button Margin="0,0,0,6"
                                                Click="ButtonSwitchUser_OnClick"
                                                Content="切换用户" />

                                        <Button Margin="0,0,0,6"
                                                Click="ButtonChangePassword_OnClick"
                                                Content="修改密码" />
                                        
                                        <Button Margin="0,0,0,0"
                                                Click="ButtonLogout_OnClick"
                                                Content="退出登录" />
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 二级导航模块 -->
                <Border Grid.Column="1"
                        Margin="0,0,12,0"
                        CornerRadius="14"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Effect="{StaticResource EffectShadow2}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="56" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="18,0"
                                CornerRadius="14,14,0,0"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock x:Name="TextBlockPrimaryTitle"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="首页" />
                        </Border>

                        <ListBox x:Name="SecondaryNavList"
                                 Grid.Row="1"
                                 Margin="8,8,8,10"
                                 SelectionChanged="SecondaryNavList_SelectionChanged"
                                 ItemContainerStyle="{StaticResource SecondaryNavItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Opacity="0.82"
                                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                                   Text="{Binding Description}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 工作区模块 -->
                <Border Grid.Column="2"
                        CornerRadius="16"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Effect="{StaticResource EffectShadow4}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="16,0"
                                CornerRadius="16,16,0,0"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <DockPanel LastChildFill="False">
                                <TextBlock x:Name="TextBlockWorkAreaTitle"
                                           DockPanel.Dock="Left"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="首页" /> 
                                <TextBlock x:Name="TextBlockWorkAreaDescription"
                                           DockPanel.Dock="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Opacity="0.7"
                                           Text="设备总览、生产摘要、快捷入口" />
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1" Margin="10">
                            <hc:TransitioningContentControl x:Name="MainFrame" Background="Transparent" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- 底部状态模块 -->
            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="14,0"
                    CornerRadius="12"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow2}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="系统就绪" />

                    <TextBlock Grid.Column="1"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="Motion: 已连接" />

                    <TextBlock Grid.Column="2"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="PLC: 已连接" />

                    <TextBlock Grid.Column="3"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="Camera: 已连接" />

                    <TextBlock Grid.Column="4"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource DangerBrush}"
                               Text="报警: 0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>
