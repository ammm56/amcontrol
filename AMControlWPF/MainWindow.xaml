<hc:GlowWindow x:Class="AMControlWPF.MainWindow"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:AMControlWPF"
               xmlns:main="clr-namespace:AMControlWPF.UserControls.Main"
               mc:Ignorable="d"
               ResizeMode="CanResizeWithGrip"
               ShowNonClientArea="True"
               WindowStartupLocation="CenterScreen"
               Background="{DynamicResource RegionBrush}"
               Title="AM运动控制"
               Icon="/Resources/Img/logo.ico"
               Height="800"
               Width="1200">
    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid x:Name="MainLayoutHost" Margin="16,16,16,12" RenderTransformOrigin="0.5,0.5">
            <Grid.CacheMode>
                <BitmapCache />
            </Grid.CacheMode>

            <Grid.RenderTransform>
                <ScaleTransform x:Name="MainLayoutScaleTransform"
                        ScaleX="1"
                        ScaleY="1" />
            </Grid.RenderTransform>

            <Grid.RowDefinitions>
                <RowDefinition x:Name="MainContentRow" Height="*" />
                <RowDefinition x:Name="MainStatusRow" Height="40" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="PrimaryNavColumn" Width="96" />
                <ColumnDefinition x:Name="SecondaryNavColumn" Width="260" />
                <ColumnDefinition x:Name="WorkAreaColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 一级导航模块 -->
            <Border Grid.Row="0"
            Grid.Column="0"
            Margin="0,0,12,0"
            Padding="8,12"
            CornerRadius="14"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Effect="{StaticResource EffectShadow2}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="PrimaryNavList"
                     Grid.Row="0"
                     SelectionChanged="PrimaryNavList_SelectionChanged"
                     ItemContainerStyle="{StaticResource PrimaryNavItemStyle}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 一级导航模块 底部的用户卡片 -->
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Button x:Name="ButtonUserCard"
                        Width="60"
                        Height="60"
                        Click="ButtonUserCard_OnClick"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center">
                                <hc:Gravatar x:Name="GravatarCurrentUser"
                                     Width="56"
                                     Height="56"
                                     Style="{StaticResource GravatarBaseStyle}"
                                     Id="am" />
                            </StackPanel>
                        </Button>

                        <Popup x:Name="PopupUserMenu"
                       PlacementTarget="{Binding ElementName=ButtonUserCard}"
                       Placement="Top"
                       VerticalOffset="-10"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                            <Border Style="{StaticResource UserPopupCardBorderStyle}">
                                <StackPanel>
                                    <Border Margin="0,0,0,0"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="{DynamicResource SecondaryRegionBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <hc:Gravatar Width="42"
                                                 Height="42"
                                                 Style="{StaticResource GravatarBaseStyle}"
                                                 Id="{Binding ElementName=GravatarCurrentUser, Path=Id}" />

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock x:Name="TextBlockPopupUserName"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="当前用户" />
                                                <TextBlock x:Name="TextBlockPopupUserRole"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Opacity="0.75"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="角色" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                    </Grid>

                                    <Grid Grid.Row="0" VerticalAlignment="Top">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        Style="{StaticResource UserPopupActionButtonStyle}"
                                        Click="ButtonSwitchUser_OnClick"
                                        Content="切换用户" />

                                        <Button Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        Style="{StaticResource UserPopupActionButtonStyle}"
                                        Click="ButtonChangePassword_OnClick"
                                        Content="修改密码" />
                                    </Grid>

                                    <Grid Grid.Row="2" VerticalAlignment="Top">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        Style="{StaticResource UserPopupActionButtonStyle}"
                                        Click="ButtonLogout_OnClick"
                                        Content="退出登录" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </Border>

            <!-- 二级导航模块 -->
            <Border Grid.Row="0"
            Grid.Column="1"
            Margin="0,0,12,0"
            CornerRadius="14"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Effect="{StaticResource EffectShadow2}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                    Padding="18,0"
                    CornerRadius="14,14,0,0"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                        <TextBlock x:Name="TextBlockPrimaryTitle"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="首页" />
                    </Border>

                    <ListBox x:Name="SecondaryNavList"
                     Grid.Row="1"
                     Margin="8,8,8,10"
                     SelectionChanged="SecondaryNavList_SelectionChanged"
                     ItemContainerStyle="{StaticResource SecondaryNavItemStyle}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                                    <TextBlock Margin="0,4,0,0"
                                       FontSize="12"
                                       Opacity="0.82"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                       Text="{Binding Description}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 工作区模块 -->
            <Border Grid.Row="0"
            Grid.Column="2"
            CornerRadius="16"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Effect="{StaticResource EffectShadow4}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                    Padding="16,0"
                    CornerRadius="16,16,0,0"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False">
                            <TextBlock x:Name="TextBlockWorkAreaTitle"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="首页" />
                            <TextBlock x:Name="TextBlockWorkAreaDescription"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Opacity="0.7"
                               Text="设备总览、生产摘要、快捷入口" />
                        </DockPanel>
                    </Border>

                    <hc:TransitioningContentControl x:Name="MainFrame"
                                            Grid.Row="1"
                                            Margin="10"
                                            Background="Transparent" />
                </Grid>
            </Border>



            <!-- 底部状态模块 -->
            <Border Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="0,12,0,0"
            Padding="14,0"
            CornerRadius="12"
            Background="{DynamicResource SecondaryRegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Effect="{StaticResource EffectShadow2}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TextBlockStatusMessage"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="系统就绪" />

                    <TextBlock Grid.Column="1"
                       Margin="0,0,16,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="Motion: 已连接" />

                    <TextBlock Grid.Column="2"
                       Margin="0,0,16,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="PLC: 已连接" />

                    <TextBlock Grid.Column="3"
                       Margin="0,0,16,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Text="Camera: 已连接" />

                    <Button x:Name="ButtonAlarmIndicator"
                    Grid.Column="4"
                    Height="28"
                    MinWidth="84"
                    Padding="12,0"
                    Click="ButtonAlarmIndicator_OnClick"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Content="报警: 0" />
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="AlarmOverlayMask"
                Panel.ZIndex="10"
                Background="#48000000"
                Visibility="Collapsed"
                MouseLeftButtonDown="AlarmOverlayMask_OnMouseLeftButtonDown" />

        <Border x:Name="BorderAlarmPanel"
                Panel.ZIndex="20"
                Width="560"
                Margin="0,16,16,12"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Visibility="Collapsed"
                CornerRadius="16"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Effect="{StaticResource EffectShadow4}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="14,0"
                        CornerRadius="16,16,0,0"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="报警抽屉" />

                        <Button DockPanel.Dock="Right"
                                Width="30"
                                Height="28"
                                Margin="8,0,0,0"
                                Padding="0"
                                Click="ButtonCloseAlarmPanel_OnClick"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                Content="✕" />
                    </DockPanel>
                </Border>

                <main:ActiveAlarmPanel x:Name="ActiveAlarmPanelControl" Grid.Row="1" />
            </Grid>
        </Border>

        <!-- Growl 通知面板：置于 MainLayoutHost 外部，避免受报警抽屉缩放变换影响 -->
        <StackPanel hc:Growl.GrowlParent="True"
            Panel.ZIndex="30"
            VerticalAlignment="Top"
            HorizontalAlignment="Right"
            Margin="0,20,20,0" />

    </Grid>
</hc:GlowWindow>