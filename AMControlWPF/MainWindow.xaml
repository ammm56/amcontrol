<hc:GlowWindow x:Class="AMControlWPF.MainWindow"
               xmlns:hc="https://handyorg.github.io/handycontrol"
               xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:local="clr-namespace:AMControlWPF"
               xmlns:main="clr-namespace:AMControlWPF.UserControls.Main"
               mc:Ignorable="d"
               ResizeMode="CanResizeWithGrip"
               ShowNonClientArea="True"
               WindowStartupLocation="CenterScreen"
               Background="{DynamicResource RegionBrush}"
               Title="AM运动控制"
               Icon="/Resources/Img/logo.ico"
               Height="800"
               Width="1200">

    <hc:GlowWindow.Resources>
        <Style x:Key="PrimaryNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="BorderRoot"
                                Margin="4,6"
                                Padding="8,12"
                                CornerRadius="10"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderRoot" Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BorderRoot" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="BorderRoot" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="BorderRoot"
                                Margin="4,6"
                                Padding="14,12"
                                CornerRadius="10"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderRoot" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BorderRoot" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="BorderRoot" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </hc:GlowWindow.Resources>

    <Grid>
        <Rectangle Fill="{StaticResource ShellTextureBrush}" />

        <Grid Margin="16,16,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 一级导航模块 -->
                <Border Grid.Column="0"
                        Margin="0,0,12,0"
                        Padding="8,12"
                        CornerRadius="14"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Effect="{StaticResource EffectShadow2}">
                    <ListBox x:Name="PrimaryNavList"
                             SelectionChanged="PrimaryNavList_SelectionChanged"
                             ItemContainerStyle="{StaticResource PrimaryNavItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- 二级导航模块 -->
                <Border Grid.Column="1"
                        Margin="0,0,12,0"
                        CornerRadius="14"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Effect="{StaticResource EffectShadow2}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="56" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="18,0"
                                CornerRadius="14,14,0,0"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock x:Name="TextBlockPrimaryTitle"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="首页" />
                        </Border>

                        <ListBox x:Name="SecondaryNavList"
                                 Grid.Row="1"
                                 Margin="8,8,8,10"
                                 SelectionChanged="SecondaryNavList_SelectionChanged"
                                 ItemContainerStyle="{StaticResource SecondaryNavItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Opacity="0.82"
                                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                                   Text="{Binding Description}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 工作区模块 -->
                <Border Grid.Column="2"
                        CornerRadius="16"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Effect="{StaticResource EffectShadow4}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="16,0"
                                CornerRadius="16,16,0,0"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="工作区" />
                                <TextBlock DockPanel.Dock="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Opacity="0.7"
                                           Text="当前模块页面内容" />
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1" Margin="10">
                            <hc:TransitioningContentControl x:Name="MainFrame"
                                                            Background="Transparent" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- 底部状态模块 -->
            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="14,0"
                    CornerRadius="12"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Effect="{StaticResource EffectShadow2}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="系统就绪" />

                    <TextBlock Grid.Column="1"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="Motion: 已连接" />

                    <TextBlock Grid.Column="2"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="PLC: 已连接" />

                    <TextBlock Grid.Column="3"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="Camera: 已连接" />

                    <TextBlock Grid.Column="4"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource DangerBrush}"
                               Text="报警: 0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</hc:GlowWindow>
